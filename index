// Flatten all custom words into a big set for validation
const VALID_ALL = new Set([
  ...Object.values(CUSTOM_WORDS).flat(),
  ...UNIQUE, ...EASY_WORDS
]);

// ══════════════════════════════════════════════
// GAME STATE
// ══════════════════════════════════════════════
let answer, currentRow, currentCol, board, keyStates, gameOver, isAnimating;
let streak = 0, bestStreak = 0, startTime;
let currentUser = null;
let gameMode = 'classic'; // 'classic' | 'blitz' | 'easy' | 'custom'
let customWordLength = 5; // used when gameMode === 'custom'
let blitzInterval = null;
let blitzSecondsLeft = 30;
let easyHintsGiven = 0; // letters already greyed for easy mode

// ══════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════
function initGame() {
  closeOverlay('end-overlay');
  clearBlitzTimer();
  easyHintsGiven = 0;

  const wordLen = gameMode === 'custom' ? customWordLength : 5;
  let pool;
  if (gameMode === 'easy') {
    pool = EASY_WORDS;
  } else if (gameMode === 'custom') {
    pool = CUSTOM_WORDS[wordLen] || [];
    if (pool.length === 0) { showToast('No words for length ' + wordLen + '!'); pool = UNIQUE; }
  } else {
    pool = UNIQUE;
  }
  answer = pool[Math.floor(Math.random() * pool.length)];

  currentRow = 0; currentCol = 0;
  const maxGuesses = gameMode === 'custom' ? Math.max(6, wordLen + 1) : 6;
  board = Array.from({length: maxGuesses}, () => Array(wordLen).fill(''));
  keyStates = {}; gameOver = false; isAnimating = false;
  startTime = Date.now();

  buildGrid(wordLen, maxGuesses); buildKeyboard();

  // Update subtitle
  const subtitle = document.querySelector('.subtitle');
  if (subtitle) {
    if (gameMode === 'custom') {
      subtitle.textContent = `Guess the ${wordLen}-letter word`;
    } else {
      subtitle.textContent = 'Guess the 5-letter word';
    }
  }

  // Easy Peazy: reveal 2 absent letters before first guess
  if (gameMode === 'easy') {
    setTimeout(() => giveEasyHint(), 300);
  }

  // Blitz: start countdown
  if (gameMode === 'blitz') {
    document.getElementById('blitz-timer-text').style.display = 'block';
    document.getElementById('blitz-bar-wrap').style.display = 'block';
    startBlitzTimer();
  } else {
    document.getElementById('blitz-timer-text').style.display = 'none';
    document.getElementById('blitz-bar-wrap').style.display = 'none';
  }
}

function buildGrid(wordLen, maxGuesses) {
  wordLen = wordLen || 5; maxGuesses = maxGuesses || 6;
  const grid = document.getElementById('grid');
  grid.innerHTML = '';
  // Adjust grid column template and tile sizing based on word length
  const tileSize = wordLen <= 6 ? 'clamp(44px,11vw,56px)' : wordLen <= 9 ? 'clamp(34px,8vw,44px)' : wordLen <= 12 ? 'clamp(26px,6vw,34px)' : 'clamp(20px,4.5vw,28px)';
  const fontSize = wordLen <= 6 ? 'clamp(1.4rem,4vw,2rem)' : wordLen <= 9 ? 'clamp(1rem,3vw,1.5rem)' : 'clamp(0.75rem,2vw,1.1rem)';
  for (let r = 0; r < maxGuesses; r++) {
    const row = document.createElement('div');
    row.className = 'row'; row.id = 'row-' + r;
    row.style.gridTemplateColumns = `repeat(${wordLen},1fr)`;
    for (let c = 0; c < wordLen; c++) {
      const tile = document.createElement('div');
      tile.className = 'tile'; tile.id = 'tile-' + r + '-' + c;
      tile.style.width = tileSize; tile.style.height = tileSize;
      tile.style.fontSize = fontSize;
      row.appendChild(tile);
    }
    grid.appendChild(row);
  }
  // Adjust grid width for long words
  const gridWidth = Math.min(wordLen * 64, window.innerWidth * 0.95);
  grid.style.width = gridWidth + 'px';
  grid.style.gridTemplateRows = `repeat(${maxGuesses},1fr)`;
}

function buildKeyboard() {
  const layout = [['Q','W','E','R','T','Y','U','I','O','P'],['A','S','D','F','G','H','J','K','L'],['ENTER','Z','X','C','V','B','N','M','⌫']];
  const kb = document.getElementById('keyboard');
  kb.innerHTML = '';
  layout.forEach(rowKeys => {
    const div = document.createElement('div');
    div.className = 'kb-row';
    rowKeys.forEach(k => {
      const btn = document.createElement('button');
      btn.className = 'key' + (k.length > 1 ? ' wide' : '');
      btn.textContent = k; btn.id = 'key-' + k;
      btn.onclick = () => handleKey(k);
      div.appendChild(btn);
    });
    kb.appendChild(div);
  });
}

// ══════════════════════════════════════════════
// EASY PEAZY HINTS
// ══════════════════════════════════════════════
function giveEasyHint() {
  const answerLetters = new Set(answer.split(''));
  // All alphabet letters not in answer
  const candidates = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('').filter(l => !answerLetters.has(l) && !keyStates[l]);

  let count = 2;
  if (currentRow >= 4 && candidates.length >= 7) count = 2;

  const chosen = candidates.sort(() => Math.random() - 0.5).slice(0, count);
  chosen.forEach(letter => {
    keyStates[letter] = 'absent';
    const el = document.getElementById('key-' + letter);
    if (el) el.className = 'key hint-used';
    easyHintsGiven++;
  });

  if (chosen.length > 0) showToast('Hint: ' + chosen.join(', ') + ' not in word');
}

// ══════════════════════════════════════════════
// BLITZ TIMER
// ══════════════════════════════════════════════
function startBlitzTimer() {
  blitzSecondsLeft = 30;
  updateBlitzUI();
  blitzInterval = setInterval(() => {
    blitzSecondsLeft--;
    updateBlitzUI();
    if (blitzSecondsLeft <= 0) {
      clearBlitzTimer();
      gameOver = true;
      showToast('Time\'s up!');
      setTimeout(() => endGame(false), 600);
    }
  }, 1000);
}

function updateBlitzUI() {
  const timerEl = document.getElementById('blitz-timer-text');
  const fillEl = document.getElementById('blitz-bar-fill');
  timerEl.textContent = blitzSecondsLeft;
  const pct = (blitzSecondsLeft / 30) * 100;
  fillEl.style.width = pct + '%';
  // Colour shift: green → yellow → red
  if (pct > 50) fillEl.style.background = 'var(--correct)';
  else if (pct > 25) fillEl.style.background = 'var(--present)';
  else {
    fillEl.style.background = '#e06060';
    timerEl.style.color = '#e06060';
    timerEl.style.animation = 'pulse 0.5s infinite';
  }
  if (pct > 25) { timerEl.style.color = 'var(--accent)'; timerEl.style.animation = 'none'; }
}

function clearBlitzTimer() {
  if (blitzInterval) { clearInterval(blitzInterval); blitzInterval = null; }
  document.getElementById('blitz-timer-text').style.animation = 'none';
}

// ══════════════════════════════════════════════
// GAME LOGIC
// ══════════════════════════════════════════════
function handleKey(k) {
  if (gameOver || isAnimating) return;
  const wordLen = answer ? answer.length : 5;
  const maxGuesses = board.length;
  if (k === '⌫' || k === 'BACKSPACE') {
    if (currentCol > 0) {
      currentCol--;
      board[currentRow][currentCol] = '';
      const tile = document.getElementById('tile-' + currentRow + '-' + currentCol);
      tile.textContent = ''; tile.classList.remove('filled');
    }
  } else if (k === 'ENTER') {
    submitGuess();
  } else if (/^[A-Z]$/.test(k) && currentCol < wordLen) {
    board[currentRow][currentCol] = k;
    const tile = document.getElementById('tile-' + currentRow + '-' + currentCol);
    tile.textContent = k; tile.classList.add('filled');
    currentCol++;
  }
}

function submitGuess() {
  const wordLen = answer ? answer.length : 5;
  if (currentCol < wordLen) { shake(); showToast('Not enough letters'); return; }
  const guess = board[currentRow].join('');
  // For custom mode, we do a lenient valid check: accept if in VALID_ALL (any length)
  if (gameMode !== 'custom' && !VALID.has(guess)) { shake(); showToast('Not in word list'); return; }
  if (gameMode === 'custom') {
    const pool = CUSTOM_WORDS[wordLen] || [];
    if (pool.length > 0 && !VALID_ALL.has(guess)) { shake(); showToast('Not in word list'); return; }
  }
  revealRow(currentRow, score(guess, answer), guess);
}

function score(guess, ans) {
  const len = ans.length;
  const res = Array(len).fill('absent');
  const ansArr = ans.split('');
  const used = Array(len).fill(false);
  for (let i = 0; i < len; i++) { if (guess[i] === ansArr[i]) { res[i] = 'correct'; used[i] = true; } }
  for (let i = 0; i < len; i++) {
    if (res[i] === 'correct') continue;
    for (let j = 0; j < len; j++) { if (!used[j] && guess[i] === ansArr[j]) { res[i] = 'present'; used[j] = true; break; } }
  }
  return res;
}

function revealRow(row, result, guess) {
  isAnimating = true;
  const maxGuesses = board.length;
  result.forEach((state, i) => {
    const tile = document.getElementById('tile-' + row + '-' + i);
    const delay = i * 300;
    setTimeout(() => {
      tile.style.animation = 'flipIn 0.5s ease ' + delay + 'ms both';
      setTimeout(() => { tile.classList.add(state); updateKey(guess[i], state); }, delay + 250);
    }, 0);
  });
  setTimeout(() => {
    const won = result.every(r => r === 'correct');
    if (won) {
      gameOver = true;
      isAnimating = false;
      clearBlitzTimer();
      bounceRow(row);
      setTimeout(() => endGame(true), 400);
    } else if (row === maxGuesses - 1) {
      gameOver = true;
      isAnimating = false;
      clearBlitzTimer();
      setTimeout(() => endGame(false), 200);
    } else {
      currentRow++; currentCol = 0;
      isAnimating = false;
      // Easy Peazy: extra hints on row 4 (5th guess) if many unknowns remain
      if (gameMode === 'easy' && currentRow === 4) {
        const ansLetters = new Set(answer.split(''));
        const remaining = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('').filter(l => !ansLetters.has(l) && !keyStates[l]);
        if (remaining.length >= 7) setTimeout(() => giveEasyHint(), 300);
      }
    }
  }, result.length * 300 + 250);
}

function updateKey(letter, state) {
  const priority = {correct:3, present:2, absent:1};
  if (!keyStates[letter] || priority[state] > priority[keyStates[letter]]) {
    keyStates[letter] = state;
    const el = document.getElementById('key-' + letter);
    if (el) el.className = 'key' + (el.classList.contains('wide') ? ' wide' : '') + ' ' + state;
  }
}

function shake() {
  const row = document.getElementById('row-' + currentRow);
  row.classList.add('shake');
  row.addEventListener('animationend', () => row.classList.remove('shake'), {once:true});
}

function bounceRow(row) {
