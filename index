// ══════════════════════════════════════════════
function applyCustomColor(type, hex) {
  const root = document.documentElement;
  if (type === 'correct') root.style.setProperty('--correct', hex);
  else if (type === 'present') root.style.setProperty('--present', hex);
  else if (type === 'absent') root.style.setProperty('--absent', hex);
  const saved = JSON.parse(localStorage.getItem('wordleColors') || '{}');
  saved[type] = hex;
  localStorage.setItem('wordleColors', JSON.stringify(saved));
  if (currentUser) syncPrefsToCloud();
}

