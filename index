.fsr-av img { width:100%; height:100%; object-fit:cover; }
/* Profile (Discord-style) */
.prof-banner { height:88px; flex-shrink:0; background:linear-gradient(135deg,#538d4e,#b59f3b); }
.prof-avatar { width:72px; height:72px; border-radius:50%; border:4px solid var(--surface); background:var(--correct); display:flex; align-items:center; justify-content:center; font-size:1.9rem; color:#fff; overflow:hidden; flex-shrink:0; }
.prof-avatar img { width:100%; height:100%; object-fit:cover; }
.prof-username { font-family:'Bebas Neue',sans-serif; font-size:1.45rem; letter-spacing:0.08em; color:var(--accent); line-height:1.1; }
.prof-displayname-sub { font-size:0.48rem; color:var(--muted); letter-spacing:0.06em; margin-top:1px; }
.prof-bio { font-size:0.57rem; color:var(--text); line-height:1.65; white-space:pre-wrap; word-break:break-word; }
.prof-section-label { font-size:0.44rem; color:var(--muted); letter-spacing:0.14em; text-transform:uppercase; margin-bottom:6px; font-weight:700; }
.prof-stat-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:7px; }
.prof-stat { background:rgba(0,0,0,0.15); border:1px solid var(--border); padding:8px 4px; text-align:center; border-radius:3px; }
