.fr-btn.msg   { border-color:var(--accent); color:var(--accent); }
.fr-btn.msg:hover   { background:var(--accent); color:var(--bg); }
.fr-empty { font-size:0.6rem; color:var(--muted); text-align:center; padding:28px 0; letter-spacing:0.08em; }
.fr-err { font-size:0.55rem; color:#e06060; min-height:14px; margin-bottom:6px; }
.online-dot { width:7px; height:7px; border-radius:50%; background:#555; display:inline-block; flex-shrink:0; }
.online-dot.on { background:var(--correct); }

/* ── DM / Chat ── */
#dm-overlay .modal { padding:0; overflow:hidden; display:flex; flex-direction:column; height:min(560px,88vh); }
.dm-header { display:flex; align-items:center; gap:10px; padding:16px 18px 14px; border-bottom:1px solid var(--border); flex-shrink:0; }
.dm-back { background:none; border:none; color:var(--muted); font-size:1rem; cursor:pointer; padding:0 4px; line-height:1; transition:color 0.15s; }
.dm-back:hover { color:var(--accent); }
.dm-avatar { width:32px; height:32px; background:var(--correct); border-radius:3px; display:flex; align-items:center; justify-content:center; color:#fff; font-size:0.95rem; flex-shrink:0; overflow:hidden; }
.dm-avatar img { width:100%; height:100%; object-fit:cover; }
.dm-title { font-size:1rem; letter-spacing:0.06em; color:var(--accent); line-height:1; }
.dm-sub   { font-size:0.44rem; color:var(--muted); margin-top:2px; letter-spacing:0.08em; }
.dm-msgs  { flex:1; overflow-y:auto; padding:14px 16px; display:flex; flex-direction:column; gap:8px; scrollbar-width:thin; scrollbar-color:var(--border) transparent; }
.dm-bubble-wrap { display:flex; flex-direction:column; gap:2px; }
.dm-bubble-wrap.me { align-items:flex-end; }
.dm-bubble-wrap.them { align-items:flex-start; }
.dm-bubble { max-width:72%; padding:9px 13px; border-radius:14px; font-size:0.65rem; line-height:1.5; word-break:break-word; }
.dm-bubble-wrap.me   .dm-bubble { background:var(--correct); color:#fff; border-bottom-right-radius:4px; }
.dm-bubble-wrap.them .dm-bubble { background:var(--surface); border:1px solid var(--border); color:var(--text); border-bottom-left-radius:4px; }
.dm-ts { font-size:0.4rem; color:var(--muted); letter-spacing:0.06em; padding:0 4px; }
.dm-input-row { display:flex; gap:8px; padding:12px 14px; border-top:1px solid var(--border); flex-shrink:0; align-items:center; }
.dm-input { flex:1; background:var(--bg); border:1px solid var(--border); color:var(--text); padding:10px 14px; font-size:0.65rem; outline:none; border-radius:20px; transition:border-color 0.15s; }
.dm-input:focus { border-color:var(--accent); }
.dm-send { width:36px; height:36px; background:var(--correct); border:none; color:#fff; border-radius:50%; cursor:pointer; font-size:1rem; display:flex; align-items:center; justify-content:center; transition:filter 0.15s; flex-shrink:0; }
.dm-send:hover { filter:brightness(1.15); }
.dm-date-divider { text-align:center; font-size:0.42rem; color:var(--muted); letter-spacing:0.12em; text-transform:uppercase; padding:4px 0; }
/* ── Hamburger ── */
.hamburger-btn { background:transparent; border:1px solid var(--border); color:var(--muted); width:34px; height:34px; cursor:pointer; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:4px; padding:6px; border-radius:3px; transition:border-color 0.15s,color 0.15s; flex-shrink:0; }
.hamburger-btn:hover { border-color:var(--accent); color:var(--accent); }
.hamburger-btn span { display:block; width:16px; height:2px; background:currentColor; border-radius:1px; transition:background 0.15s; }
/* Sidebar nav items */
.sb-item { display:flex; align-items:center; gap:10px; padding:11px 18px; font-size:0.6rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--text); cursor:pointer; transition:background 0.12s, color 0.12s; }
.sb-item:hover { background:rgba(232,213,183,0.06); color:var(--accent); }
/* Online status */
.status-dot { width:9px; height:9px; border-radius:50%; flex-shrink:0; border:2px solid var(--surface); }
.status-dot.online { background:#3ecf8e; }
.status-dot.idle   { background:#f59e0b; }
.status-dot.offline{ background:#555; }
/* Read receipt */
.dm-receipt { font-size:0.38rem; color:var(--muted); letter-spacing:0.06em; padding:1px 4px 2px; }
.dm-receipt.read { color:#3ecf8e; }
/* DM image */
.dm-img { max-width:200px; max-height:200px; border-radius:8px; display:block; cursor:zoom-in; transition:opacity 0.15s; }
.dm-img:hover { opacity:0.85; }
/* Image lightbox */
#img-lightbox { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.9); z-index:9999; align-items:center; justify-content:center; cursor:zoom-out; }
#img-lightbox.open { display:flex; }
#img-lightbox img { max-width:92vw; max-height:92vh; border-radius:6px; object-fit:contain; box-shadow:0 8px 40px rgba(0,0,0,0.6); }
/* Reply bar above input */
#dm-reply-bar { display:none; padding:6px 12px 4px; border-top:1px solid var(--border); background:rgba(0,0,0,0.15); flex-direction:row; align-items:center; gap:8px; flex-shrink:0; }
#dm-reply-bar.open { display:flex; }
.dm-reply-quote { background:rgba(255,255,255,0.08); border-left:3px solid var(--accent); padding:4px 8px; border-radius:3px; margin-bottom:5px; font-size:0.44rem; color:var(--muted); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; max-width:100%; }
.dm-bubble-wrap.me .dm-reply-quote { background:rgba(0,0,0,0.18); border-left-color:rgba(255,255,255,0.35); }
.dm-reactions { display:flex; flex-wrap:wrap; gap:3px; margin-top:4px; }
.dm-reaction { background:rgba(255,255,255,0.07); border:1px solid var(--border); border-radius:10px; padding:2px 7px; font-size:0.82rem; cursor:pointer; transition:background 0.1s,transform 0.1s; display:inline-flex; align-items:center; gap:3px; }
.dm-reaction:hover { background:rgba(255,255,255,0.14); transform:scale(1.08); }
.dm-reaction.mine { background:rgba(83,141,78,0.22); border-color:var(--correct); }
.dm-reaction-count { font-size:0.4rem; color:var(--muted); }
.dm-bubble-outer { position:relative; display:flex; flex-direction:column; }
.dm-bubble-wrap.me .dm-bubble-outer  { align-items:flex-end; }
.dm-bubble-wrap.them .dm-bubble-outer { align-items:flex-start; }
.dm-bubble-actions { display:none; position:absolute; top:-32px; background:var(--surface); border:1px solid var(--border); border-radius:20px; padding:3px 6px; gap:1px; flex-direction:row; z-index:5; box-shadow:0 4px 14px rgba(0,0,0,0.4); }
.dm-bubble-wrap.me .dm-bubble-actions  { right:0; }
.dm-bubble-wrap.them .dm-bubble-actions { left:0; }
.dm-bubble-outer:hover .dm-bubble-actions { display:flex; }
.dm-action-btn { background:none; border:none; font-size:0.95rem; cursor:pointer; padding:2px 5px; border-radius:50%; line-height:1; transition:background 0.1s; }
.dm-action-btn:hover { background:rgba(255,255,255,0.1); }
#msg-notif { display:none; position:fixed; bottom:22px; right:20px; background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:13px 15px 12px; z-index:8888; width:288px; box-shadow:0 6px 28px rgba(0,0,0,0.55); }
#msg-notif.open { display:block; animation:slideInNotif 0.3s cubic-bezier(0.34,1.5,0.64,1); }
@keyframes slideInNotif { from { transform:translateY(24px) scale(0.95); opacity:0; } to { transform:none; opacity:1; } }
.notif-header { display:flex; align-items:center; gap:9px; margin-bottom:6px; }
.notif-avatar { width:30px; height:30px; border-radius:50%; background:var(--correct); display:flex; align-items:center; justify-content:center; color:#fff; font-size:0.9rem; overflow:hidden; flex-shrink:0; }
.notif-avatar img { width:100%;height:100%;object-fit:cover; }
.notif-name { font-size:0.6rem; font-weight:700; color:var(--accent); flex:1; letter-spacing:0.04em; }
.notif-close-btn { background:none; border:none; color:var(--muted); cursor:pointer; font-size:1.1rem; line-height:1; padding:0 3px; }
.notif-preview { font-size:0.52rem; color:var(--text); margin-bottom:10px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; opacity:0.8; padding-left:39px; }
.notif-btns { display:flex; gap:6px; }
.notif-btn { flex:1; padding:7px 4px; background:transparent; border:1px solid var(--border); color:var(--muted); font-size:0.47rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; cursor:pointer; border-radius:5px; transition:all 0.12s; }
.notif-btn.primary { background:var(--correct); border-color:var(--correct); color:#fff; }
.notif-btn:not(.primary):hover { border-color:var(--accent); color:var(--accent); }
.notif-btn.primary:hover { filter:brightness(1.12); }
#notif-reply-area { display:none; margin-top:9px; gap:5px; flex-direction:column; }
#notif-reply-area.open { display:flex; }
#notif-reply-input { background:rgba(0,0,0,0.22); border:1px solid var(--border); color:var(--text); padding:7px 10px; font-size:0.54rem; border-radius:5px; outline:none; width:100%; box-sizing:border-box; }
#notif-reply-input:focus { border-color:var(--accent); }
#notif-reply-send { padding:7px; background:var(--correct); border:none; color:#fff; font-size:0.5rem; font-weight:700; cursor:pointer; border-radius:5px; letter-spacing:0.08em; text-transform:uppercase; }
/* Emoji picker */
#dm-emoji-picker { display:none; position:absolute; bottom:62px; left:0; right:0; background:var(--surface); border:1px solid var(--border); border-top-left-radius:8px; border-top-right-radius:8px; padding:10px 8px; z-index:10; flex-wrap:wrap; gap:2px; max-height:150px; overflow-y:auto; }
#dm-emoji-picker.open { display:flex; }
/* Friend search dropdown */
#fr-search-results { border:1px solid var(--border); border-radius:4px; overflow:hidden; margin-bottom:8px; display:none; }
#fr-search-results.open { display:block; }
.fsr-item { display:flex; align-items:center; gap:10px; padding:9px 12px; cursor:pointer; transition:background 0.1s; border-bottom:1px solid var(--border); }
