let snakeState = null, snakeInterval = null;
function initSnake() {
  clearInterval(snakeInterval);
  const best = parseInt(localStorage.getItem('snakeHigh')||'0');
  snakeState = { cells:20, size:16, snake:[{x:10,y:10},{x:9,y:10}], dir:{x:1,y:0}, nextDir:{x:1,y:0}, apple:null, score:0, best, running:false, over:false };
  snakeState.apple = _snakeApple();
  document.getElementById('snake-score').textContent = '0';
  document.getElementById('snake-best').textContent = best;
  const c = document.getElementById('snake-canvas');
  c.addEventListener('keydown', e => {
    if(e.key==='ArrowUp')snakeDir(0,-1);
    else if(e.key==='ArrowDown')snakeDir(0,1);
    else if(e.key==='ArrowLeft')snakeDir(-1,0);
    else if(e.key==='ArrowRight')snakeDir(1,0);
    else if(e.key===' ')_snakeStart();
    e.preventDefault();
  }, { once:false });
  c.addEventListener('click', _snakeStart);
  c.focus();
  _snakeDraw();
}

function _snakeStart() {
  if (snakeState.over) { initSnake(); return; }
  if (!snakeState.running) {
    snakeState.running = true;
    snakeInterval = setInterval(_snakeTick, 140);
  }
}

function snakeDir(dx, dy) {
  if (!snakeState) return;
  _snakeStart();
  // Prevent reversing
  if (snakeState.snake.length > 1 && snakeState.dir.x === -dx && snakeState.dir.y === -dy) return;
  snakeState.nextDir = { x:dx, y:dy };
}

function _snakeApple() {
  const { cells, snake } = snakeState;
  let pos;
  do { pos = { x:Math.floor(Math.random()*cells), y:Math.floor(Math.random()*cells) }; }
  while (snake.some(s => s.x===pos.x && s.y===pos.y));
  return pos;
}

function _snakeTick() {
  const s = snakeState;
  if (!s || s.over) { clearInterval(snakeInterval); return; }
  s.dir = s.nextDir;
  const head = { x:(s.snake[0].x+s.dir.x+s.cells)%s.cells, y:(s.snake[0].y+s.dir.y+s.cells)%s.cells };
  if (s.snake.some(seg => seg.x===head.x && seg.y===head.y)) {
    s.over = true; clearInterval(snakeInterval);
    if (s.score > s.best) { s.best = s.score; localStorage.setItem('snakeHigh', s.score); document.getElementById('snake-best').textContent = s.score; }
    _snakeDraw(); return;
  }
  s.snake.unshift(head);
  if (head.x===s.apple.x && head.y===s.apple.y) {
    s.score++; document.getElementById('snake-score').textContent = s.score;
    s.apple = _snakeApple();
  } else {
    s.snake.pop();
  }
  _snakeDraw();
}

function _snakeDraw() {
  const canvas = document.getElementById('snake-canvas'); if (!canvas) return;
  const s = snakeState; const ctx = canvas.getContext('2d');
  const sz = Math.floor(canvas.width / s.cells);
  const fg = getComputedStyle(document.documentElement).getPropertyValue('--text').trim();
  const bg = getComputedStyle(document.documentElement).getPropertyValue('--bg').trim();
  const gc = getComputedStyle(document.documentElement).getPropertyValue('--correct').trim();
  const ac = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim();
  ctx.fillStyle = bg; ctx.fillRect(0,0,canvas.width,canvas.height);
  // Grid dots
  ctx.fillStyle = 'rgba(128,128,128,0.08)';
  for (let x=0;x<s.cells;x++) for (let y=0;y<s.cells;y++) ctx.fillRect(x*sz+sz/2-1,y*sz+sz/2-1,2,2);
  // Snake
  s.snake.forEach((seg,i) => {
    ctx.fillStyle = i===0 ? ac : gc;
    ctx.fillRect(seg.x*sz+1, seg.y*sz+1, sz-2, sz-2);
  });
  // Apple
  ctx.fillStyle = '#e06060';
  const a = s.apple; ctx.beginPath(); ctx.arc(a.x*sz+sz/2, a.y*sz+sz/2, sz/2-2, 0, Math.PI*2); ctx.fill();
  // Overlay
  if (!s.running || s.over) {
    ctx.fillStyle = 'rgba(0,0,0,0.45)'; ctx.fillRect(0,0,canvas.width,canvas.height);
    ctx.fillStyle = fg; ctx.font = `bold 18px 'Space Mono',monospace`; ctx.textAlign='center';
    ctx.fillText(s.over ? 'GAME OVER' : 'TAP TO START', canvas.width/2, canvas.height/2 - 8);
    ctx.font = `11px 'Space Mono',monospace`; ctx.fillStyle='rgba(255,255,255,0.5)';
    if (s.over) ctx.fillText(`Score: ${s.score}`, canvas.width/2, canvas.height/2+14);
    else ctx.fillText('Arrow keys or buttons', canvas.width/2, canvas.height/2+14);
    ctx.textAlign='left';
  }
}

