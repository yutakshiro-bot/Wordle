}

async function pushStatus() {
  if (!currentUser || !IS_CONFIGURED) return;
  const status = document.hidden ? 'idle' : 'online';
  // Update locally then push
  const users = await fetchDB();
  const me = users[currentUser];
  if (!me) return;
  me.lastSeen = { ts: Date.now(), status };
