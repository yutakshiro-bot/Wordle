let t2State = null;
const T2COLORS = {2:'#eee4da',4:'#ede0c8',8:'#f2b179',16:'#f59563',32:'#f67c5f',64:'#f65e3b',128:'#edcf72',256:'#edcc61',512:'#edc850',1024:'#edc53f',2048:'#edc22e'};

function init2048() {
  const best = parseInt(localStorage.getItem('2048high')||'0');
  t2State = { grid:Array(4).fill(null).map(()=>Array(4).fill(0)), score:0, best, over:false, won:false };
  document.getElementById('t-score').textContent = '0';
  document.getElementById('t-best').textContent = best;
  document.getElementById('t-msg').textContent = '';
  _t2AddTile(); _t2AddTile(); _t2Render();
  const board = document.getElementById('t-board');
  board.focus();
  board.onkeydown = e => {
    if(e.key==='ArrowUp')t2048Move('up');
    else if(e.key==='ArrowDown')t2048Move('down');
    else if(e.key==='ArrowLeft')t2048Move('left');
    else if(e.key==='ArrowRight')t2048Move('right');
    else return; e.preventDefault();
  };
}

function _t2AddTile() {
  const empty = [];
  t2State.grid.forEach((row,r) => row.forEach((v,c) => { if (!v) empty.push([r,c]); }));
  if (!empty.length) return;
  const [r,c] = empty[Math.floor(Math.random()*empty.length)];
  t2State.grid[r][c] = Math.random()<0.9?2:4;
}

function t2048Move(dir) {
  if (!t2State || t2State.over) return;
  const g = t2State.grid.map(r=>[...r]);
  let moved = false, gained = 0;
  function slideRow(row) {
    let r = row.filter(v=>v);
    for (let i=0;i<r.length-1;i++) { if(r[i]===r[i+1]){ gained+=r[i]*2; r[i]*=2; r.splice(i+1,1); moved=true; } }
    while(r.length<4) r.push(0);
    return r;
  }
  function rotCW(g){ return g[0].map((_,i)=>g.map(r=>r[i]).reverse()); }
  function rotCCW(g){ return g[0].map((_,i)=>g.map(r=>r[r.length-1-i])); }
  let grid = t2State.grid;
  const rotations = {left:0,up:1,right:2,down:3};
  const rots = rotations[dir];
  for(let i=0;i<rots;i++) grid=rotCW(grid);
  const prev = grid.map(r=>[...r]);
  grid = grid.map(r => slideRow(r));
  if(!moved) moved = grid.some((r,i)=>r.some((v,j)=>v!==prev[i][j]));
  for(let i=0;i<(4-rots)%4;i++) grid=rotCW(grid);
  if(!moved) return;
  t2State.grid = grid;
  t2State.score += gained;
  if(t2State.score > t2State.best){ t2State.best=t2State.score; localStorage.setItem('2048high',t2State.score); }
  document.getElementById('t-score').textContent = t2State.score;
  document.getElementById('t-best').textContent = t2State.best;
  _t2AddTile();
  // Check win/loss
  const flat = t2State.grid.flat();
  if(flat.includes(2048) && !t2State.won){ t2State.won=true; document.getElementById('t-msg').textContent='🎉 2048!'; }
  if(!flat.includes(0) && !t2State.grid.some((r,ri)=>r.some((v,ci)=>(ri<3&&v===t2State.grid[ri+1][ci])||(ci<3&&v===r[ci+1])))){ t2State.over=true; document.getElementById('t-msg').textContent='Game over!'; }
  _t2Render();
}

function _t2Render() {
  const board = document.getElementById('t-board'); if (!board) return;
  board.innerHTML = '';
  t2State.grid.forEach(row => row.forEach(v => {
    const cell = document.createElement('div');
    const bg = T2COLORS[v] || (v?'#3d3a33':'rgba(255,255,255,0.05)');
    const textColor = v<=4?'#776e65':'#f9f6f0';
    const fs = v>=1024?'0.8rem':v>=128?'1rem':'1.2rem';
    cell.style.cssText=`aspect-ratio:1;background:${bg};display:flex;align-items:center;justify-content:center;font-weight:700;font-size:${fs};color:${textColor};border-radius:4px;transition:background 0.1s;`;
    if(v) cell.textContent = v;
    board.appendChild(cell);
  }));
}

