function getStatusClass(username) {
  // Uses cached DB data — pass users object for accuracy, else returns 'offline'
  return _statusClassFromCache(username);
}
let _lastUsersForStatus = {};
function _statusClassFromCache(username) {
  const u = _lastUsersForStatus[username];
  if (!u || !u.lastSeen) return 'offline';
  const diff = Date.now() - u.lastSeen.ts;
  if (diff > 120000) return 'offline';
  if (u.lastSeen.status === 'idle' || diff > 40000) return 'idle';
  return 'online';
}
function _statusLabel(cls) {
  return cls === 'online' ? '🟢 Online' : cls === 'idle' ? '🟡 Idle' : '⚫ Offline';
}

