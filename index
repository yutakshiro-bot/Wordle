function startReply(ts, from, previewText) {
  _pendingReplyTs = ts;
  const bar = document.getElementById('dm-reply-bar');
  const preview = document.getElementById('dm-reply-bar-preview');
  if (bar) bar.classList.add('open');
  if (preview) preview.textContent = from + ': ' + previewText;
  const input = document.getElementById('dm-input');
  if (input) input.focus();
}

function cancelReply() {
  _pendingReplyTs = null;
  const bar = document.getElementById('dm-reply-bar');
  if (bar) bar.classList.remove('open');
}

function scrollToMsg(ts) {
  const el = document.querySelector(`[data-msg-ts="${ts}"]`);
  if (el) {
    el.scrollIntoView({ behavior:'smooth', block:'center' });
    el.style.transition = 'background 0.3s';
    el.style.background = 'rgba(232,213,183,0.12)';
    setTimeout(() => { el.style.background = ''; }, 1200);
  }
}

// ══════════════════════════════════════════════
// EMOJI REACTIONS
// ══════════════════════════════════════════════
async function toggleReaction(msgTs, emoji) {
  if (!currentUser || !currentDMUser) return;
  const partner = currentDMUser;
  dbCache = null;
  const users = await fetchDB();
  const me = users[currentUser];
  const them = users[partner];
  if (!me || !them) return;
  ensureSocialFields(me);
  ensureSocialFields(them);

  // Toggle reaction in both users' copies of the conversation
  function applyReaction(convo) {
    const msg = convo.find(m => m.ts === msgTs);
    if (!msg) return;
    if (!msg.reactions) msg.reactions = {};
    if (msg.reactions[currentUser] === emoji) {
      delete msg.reactions[currentUser]; // remove if same
    } else {
      msg.reactions[currentUser] = emoji; // set/change
    }
  }
  applyReaction(me.messages[partner] || []);
  applyReaction(them.messages[currentUser] || []);

  dbDirty = true;
  await pushDB();
  dbCache = null;
  await renderDMMessages();
}

// ══════════════════════════════════════════════
// MESSAGE NOTIFICATION POPUP
// ══════════════════════════════════════════════
let _notifPartner = null;
let _notifDismissTimer = null;

function showMessageNotif(fromUser, previewText, users) {
  // Don't show if DM with that person is already open
  if (currentDMUser === fromUser && document.getElementById('dm-overlay').classList.contains('show')) return;
  _notifPartner = fromUser;

  // Avatar
  const av = document.getElementById('notif-avatar');
  const u = (users || {})[fromUser] || {};
  const photo = (u.prefs && u.prefs.pfp && u.prefs.pfp !== '__toobig__') ? u.prefs.pfp : localStorage.getItem('wordleProfilePhoto_' + fromUser);
  if (photo) { av.innerHTML = `<img src="${photo}" alt="">`; av.style.background='none'; }
  else { av.innerHTML = fromUser[0].toUpperCase(); av.style.background='var(--correct)'; }

  document.getElementById('notif-name').textContent = u.displayName || fromUser;
  const preview = previewText.startsWith('__IMG__') ? '🖼 Sent an image' : previewText;
  document.getElementById('notif-preview').textContent = preview;

  // Reset reply area
  document.getElementById('notif-reply-area').classList.remove('open');
  document.getElementById('notif-reply-input').value = '';

  const notif = document.getElementById('msg-notif');
  notif.classList.remove('open');
  // Force reflow for re-animation
  void notif.offsetWidth;
  notif.classList.add('open');

  // Auto-dismiss after 8 seconds
  clearTimeout(_notifDismissTimer);
  _notifDismissTimer = setTimeout(closeNotif, 8000);
}

function closeNotif() {
  clearTimeout(_notifDismissTimer);
  document.getElementById('msg-notif').classList.remove('open');
  _notifPartner = null;
}

function notifOpen() {
  const partner = _notifPartner;
  closeNotif();
  if (partner) openDM(partner);
}

function notifReply() {
  document.getElementById('notif-reply-area').classList.add('open');
  document.getElementById('notif-reply-input').focus();
}

async function notifSendReply() {
  const input = document.getElementById('notif-reply-input');
  const text = input.value.trim();
  if (!text || !_notifPartner) return;
  const partner = _notifPartner;
  input.value = '';
  closeNotif();

  // Send message directly without opening DM
  const ts = Date.now();
  dbCache = null;
  const users = await fetchDB();
  const me = users[currentUser];
  const them = users[partner];
  if (!me || !them) { showToast('Could not send'); return; }
  ensureSocialFields(me);
  ensureSocialFields(them);

  const myConvo = me.messages[partner] = me.messages[partner] || [];
  const theirConvo = them.messages[currentUser] = them.messages[currentUser] || [];
  if (!myConvo.some(m => m.ts === ts)) myConvo.push({ from:currentUser, text, ts, read:true });
  if (!theirConvo.some(m => m.ts === ts)) theirConvo.push({ from:currentUser, text, ts, read:false });
  if (myConvo.length > 200) me.messages[partner] = myConvo.slice(-200);
  if (theirConvo.length > 200) them.messages[currentUser] = theirConvo.slice(-200);

  dbDirty = true;
  await pushDB();
  showToast('Reply sent to ' + (them.displayName || partner) + '!');
}

// ══════════════════════════════════════════════
// KEYBOARD INPUT
// ══════════════════════════════════════════════
document.addEventListener('keydown', e => {
  if (e.ctrlKey || e.altKey || e.metaKey) return;
  // Don't handle game keys when any modal is open
  if (document.querySelector('.overlay.show')) return;
  if (e.key === 'Backspace') handleKey('BACKSPACE');
  else if (e.key === 'Enter') handleKey('ENTER');
  else if (/^[a-zA-Z]$/.test(e.key)) handleKey(e.key.toUpperCase());
});

// Close overlays by clicking backdrop
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.overlay').forEach(el => {
    el.addEventListener('click', function(e) {
      if (e.target === this) this.classList.remove('show');
    });
  });
});

