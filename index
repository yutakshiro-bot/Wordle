// FRIENDS & MESSAGING SYSTEM
// ══════════════════════════════════════════════
let currentDMUser = null;
let dmPollInterval = null;
let frPollInterval = null;
let frCurrentTab = 'friends';

// ── Normalise: ensure friends/messages fields exist ──
function ensureSocialFields(user) {
  if (!Array.isArray(user.friends))        user.friends = [];
  if (!Array.isArray(user.friendRequests)) user.friendRequests = [];
  if (!Array.isArray(user.sentRequests))   user.sentRequests = [];
  if (typeof user.messages !== 'object' || user.messages === null) user.messages = {};
}

// ── Open/close friends panel ──
function openFriends() {
  if (!currentUser) {
    document.getElementById('fr-not-logged-in').style.display = 'block';
    document.getElementById('fr-main').style.display = 'none';
  } else {
    document.getElementById('fr-not-logged-in').style.display = 'none';
    document.getElementById('fr-main').style.display = 'flex';
    loadFriendsPanel();
    // Auto-refresh friends panel every 8s while open
    clearInterval(frPollInterval);
    frPollInterval = setInterval(() => {
      if (document.getElementById('friends-overlay').classList.contains('show') && !document.getElementById('dm-overlay').classList.contains('show')) {
        loadFriendsPanel();
      } else if (!document.getElementById('friends-overlay').classList.contains('show')) {
        clearInterval(frPollInterval);
        frPollInterval = null;
      }
    }, 8000);
  }
  openOverlay('friends-overlay');
}

function switchFrTab(tab) {
  frCurrentTab = tab;
  ['friends','requests','sent'].forEach(t => {
    document.getElementById('frtab-' + t).classList.toggle('active', t === tab);
    document.getElementById('fr-tab-' + t).style.display = t === tab ? 'flex' : 'none';
  });
}

// ── Load & render the friends panel ──
async function loadFriendsPanel() {
  ['friends','requests','sent'].forEach(t => {
    document.getElementById('fr-tab-' + t).innerHTML = '<div class="fr-empty">Loading…</div>';
  });
  const users = await fetchDB();
  _lastUsersForStatus = users;
  const me = users[currentUser];
  if (!me) return;
  ensureSocialFields(me);

  // Build pfpMap for all relevant users
  const pfpMap = buildPfpMap(users);

  // ── Friends tab ──
  const frList = document.getElementById('fr-tab-friends');
  if (me.friends.length === 0) {
    frList.innerHTML = '<div class="fr-empty">No friends yet — add someone!</div>';
  } else {
    frList.innerHTML = '';
    me.friends.forEach(name => {
      const u = users[name] || {};
      const unread = getUnreadCount(me, name);
      frList.appendChild(makeFriendRow(name, u, pfpMap[name], [
        `<button class="fr-btn msg" onclick="openDM('${esc(name)}')">💬 Message${unread ? ` <b>(${unread})</b>` : ''}</button>`,
        `<button class="fr-btn deny" onclick="removeFriend('${esc(name)}')">Remove</button>`
      ]));
    });
  }

  // ── Requests tab ──
  const reqList = document.getElementById('fr-tab-requests');
  const badge = document.getElementById('frbadge-requests');
  if (me.friendRequests.length === 0) {
    reqList.innerHTML = '<div class="fr-empty">No pending requests</div>';
    badge.style.display = 'none';
  } else {
    badge.textContent = me.friendRequests.length;
    badge.style.display = 'inline-block';
    reqList.innerHTML = '';
    me.friendRequests.forEach(name => {
      const u = users[name] || {};
      reqList.appendChild(makeFriendRow(name, u, pfpMap[name], [
        `<button class="fr-btn accept" onclick="acceptFriend('${esc(name)}')">Accept</button>`,
        `<button class="fr-btn deny"   onclick="denyFriend('${esc(name)}')">Decline</button>`
      ]));
    });
  }

  // ── Sent tab ──
  const sentList = document.getElementById('fr-tab-sent');
  if (me.sentRequests.length === 0) {
    sentList.innerHTML = '<div class="fr-empty">No sent requests</div>';
  } else {
    sentList.innerHTML = '';
    me.sentRequests.forEach(name => {
      const u = users[name] || {};
      sentList.appendChild(makeFriendRow(name, u, pfpMap[name], [
        `<button class="fr-btn deny" onclick="cancelFriendRequest('${esc(name)}')">Cancel</button>`
      ]));
    });
  }

  updateFriendsBadge(me);
}

function buildPfpMap(users) {
  const map = {};
  Object.entries(users).forEach(([name, data]) => {
    if (!data || !data.email) return;
    if (data.prefs && data.prefs.pfp && data.prefs.pfp !== '__toobig__') {
      map[name] = data.prefs.pfp;
    } else {
      const local = localStorage.getItem('wordleProfilePhoto_' + name);
      if (local) map[name] = local;
    }
  });
  return map;
}

function makeFriendRow(name, userData, photo, actionHtmlArr) {
  const row = document.createElement('div');
  row.className = 'fr-row';
  const displayName = userData.displayName || name;
  const initial = displayName[0].toUpperCase();
  const cls = _statusClassFromCache(name);
  const avatarContent = photo
    ? `<img src="${photo}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`
    : initial;
  const avStyle = photo ? 'background:none;' : 'background:var(--correct);';
  row.innerHTML = `
    <div style="position:relative;flex-shrink:0;cursor:pointer;" onclick="openProfile('${esc(name)}')">
      <div class="fr-avatar" style="${avStyle}">${avatarContent}</div>
      <span class="status-dot ${cls}" style="position:absolute;bottom:-1px;right:-1px;width:10px;height:10px;border-radius:50%;border:2px solid var(--surface);"></span>
    </div>
    <div class="fr-info" style="cursor:pointer;" onclick="openProfile('${esc(name)}')">
      <div class="fr-name">${esc(displayName)}</div>
      <div class="fr-sub">${_statusLabel(cls)}${userData.totalWins ? ' · ' + userData.totalWins + ' wins' : ''}</div>
    </div>
    <div class="fr-actions">${actionHtmlArr.join('')}</div>
  `;
  return row;
}

function esc(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function updateFriendsBadge(me) {
  const badge = document.getElementById('friends-badge');
  if (!badge) return;
  const count = (me.friendRequests || []).length + getTotalUnread(me);
  if (count > 0) {
    badge.textContent = count > 9 ? '9+' : count;
    badge.style.display = 'flex';
  } else {
    badge.style.display = 'none';
  }
}

function getTotalUnread(me) {
  let total = 0;
  Object.keys(me.messages || {}).forEach(partner => {
    total += getUnreadCount(me, partner);
  });
  return total;
}

function getUnreadCount(me, partner) {
  const msgs = (me.messages || {})[partner] || [];
  return msgs.filter(m => m.from === partner && !m.read).length;
}

// ── Live user search ──
let _searchDebounce = null;
async function searchUsersLive(query) {
  const resultsEl = document.getElementById('fr-search-results');
  if (!resultsEl) return;
  clearTimeout(_searchDebounce);
  if (!query || query.length < 1) { resultsEl.classList.remove('open'); resultsEl.innerHTML = ''; return; }
  _searchDebounce = setTimeout(async () => {
    if (!IS_CONFIGURED) return;
    const users = await fetchDB();
    _lastUsersForStatus = users;
    const q = query.toLowerCase();
    const me = users[currentUser] || {};
    ensureSocialFields(me);
    const matches = Object.keys(users).filter(u =>
      u !== currentUser && (u.toLowerCase().includes(q) || ((users[u].displayName||'').toLowerCase().includes(q)))
    ).slice(0, 8);
    if (matches.length === 0) { resultsEl.classList.remove('open'); return; }
    const pfpMap = buildPfpMap(users);
    resultsEl.innerHTML = matches.map(name => {
      const u = users[name] || {};
      const photo = pfpMap[name];
      const av = photo ? `<img src="${photo}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">` : (u.displayName||name)[0].toUpperCase();
      const cls = _statusClassFromCache(name);
      const statusDot = `<span class="status-dot ${cls}" style="position:absolute;bottom:-1px;right:-1px;width:9px;height:9px;border-radius:50%;border:2px solid var(--surface);"></span>`;
      const isFriend = me.friends.includes(name);
      const hasSent = me.sentRequests.includes(name);
      const actionLabel = isFriend ? '✓ Friends' : hasSent ? 'Sent' : '+ Add';
      const actionColor = isFriend ? 'var(--correct)' : hasSent ? 'var(--muted)' : 'var(--accent)';
      const disabled = isFriend || hasSent ? 'disabled style="opacity:0.5;cursor:default;"' : `onclick="quickAddFriend('${esc(name)}')"`;
      return `<div class="fsr-item" onclick="openProfile('${esc(name)}')">
        <div class="fsr-av" style="position:relative;">${av}${statusDot}</div>
        <div style="flex:1;min-width:0;">
          <div style="font-size:0.6rem;font-weight:700;color:var(--text);letter-spacing:0.04em;">${esc(u.displayName||name)}</div>
          ${u.displayName ? `<div style="font-size:0.44rem;color:var(--muted);">@${esc(name)}</div>` : ''}
        </div>
        <button ${disabled} style="padding:4px 10px;background:transparent;border:1px solid ${actionColor};color:${actionColor};font-size:0.48rem;font-weight:700;cursor:pointer;border-radius:3px;flex-shrink:0;" onclick="event.stopPropagation();quickAddFriend('${esc(name)}')">${actionLabel}</button>
      </div>`;
    }).join('');
    resultsEl.classList.add('open');
  }, 300);
}

async function quickAddFriend(target) {
  document.getElementById('fr-search-input').value = target;
  await sendFriendRequest(target);
}

// ── Send friend request ──
async function sendFriendRequest(forcedTarget) {
  if (!currentUser) { showToast('Log in first!'); return; }
  const rawTarget = forcedTarget || document.getElementById('fr-search-input').value.trim();
  const errEl = document.getElementById('fr-search-err');
  if (errEl) errEl.textContent = '';
  if (!rawTarget) { if (errEl) errEl.textContent = 'Enter a username.'; return; }

  dbCache = null;
  const users = await fetchDB();
  // Case-insensitive target match
  const target = Object.keys(users).find(k => k.toLowerCase() === rawTarget.toLowerCase()) || rawTarget;

  if (target.toLowerCase() === currentUser.toLowerCase()) {
    if (errEl) errEl.textContent = "You can't add yourself!"; return;
  }
  if (errEl) errEl.textContent = 'Sending…';

  const me = users[currentUser];
  const them = users[target];
  if (!me)   { if (errEl) errEl.textContent = 'Your account not found.'; return; }
  if (!them) { if (errEl) errEl.textContent = 'User not found.'; return; }
  ensureSocialFields(me);
  ensureSocialFields(them);

  if (me.friends.includes(target))           { if (errEl) errEl.textContent = 'Already friends!'; return; }
  if (me.sentRequests.includes(target))      { if (errEl) errEl.textContent = 'Request already sent.'; return; }
  if (me.friendRequests.includes(target)) {
    await acceptFriendWith(target, users);
    if (errEl) errEl.textContent = '';
    const inp = document.getElementById('fr-search-input'); if (inp) inp.value = '';
    showToast('You\'re now friends with ' + (users[target].displayName||target) + '!');
    loadFriendsPanel();
    return;
  }

  them.friendRequests.push(currentUser);
  me.sentRequests.push(target);
  dbDirty = true;
  await pushDB();
  dbCache = null;
  const inp = document.getElementById('fr-search-input'); if (inp) inp.value = '';
  const res = document.getElementById('fr-search-results'); if (res) { res.innerHTML=''; res.classList.remove('open'); }
  if (errEl) { errEl.style.color = 'var(--correct)'; errEl.textContent = '✓ Request sent to ' + target + '!'; setTimeout(() => { if (errEl) { errEl.textContent=''; errEl.style.color=''; } }, 3000); }
  loadFriendsPanel();
}

async function acceptFriend(name) {
  dbCache = null;
  const users = await fetchDB();
  await acceptFriendWith(name, users);
  showToast('You and ' + name + ' are now friends!');
  loadFriendsPanel();
}

async function acceptFriendWith(name, users) {
  const me   = users[currentUser];
  const them = users[name];
  if (!me || !them) return;
  ensureSocialFields(me);
  ensureSocialFields(them);

  // Add each other as friends
  if (!me.friends.includes(name))   me.friends.push(name);
  if (!them.friends.includes(currentUser)) them.friends.push(currentUser);

  // Remove from requests & sent
  me.friendRequests  = me.friendRequests.filter(r => r !== name);
  me.sentRequests    = me.sentRequests.filter(r => r !== name);
  them.friendRequests = them.friendRequests.filter(r => r !== currentUser);
  them.sentRequests   = them.sentRequests.filter(r => r !== currentUser);

  dbDirty = true;
  await pushDB();
  dbCache = null;
}

async function denyFriend(name) {
  dbCache = null;
  const users = await fetchDB();
  const me = users[currentUser];
  if (!me) return;
  ensureSocialFields(me);
  me.friendRequests = me.friendRequests.filter(r => r !== name);
  // Also remove from their sent list
  const them = users[name];
  if (them) { ensureSocialFields(them); them.sentRequests = them.sentRequests.filter(r => r !== currentUser); }
  dbDirty = true;
  await pushDB();
  dbCache = null;
  loadFriendsPanel();
}

async function cancelFriendRequest(name) {
  dbCache = null;
  const users = await fetchDB();
  const me   = users[currentUser];
  const them = users[name];
  if (!me) return;
  ensureSocialFields(me);
  me.sentRequests = me.sentRequests.filter(r => r !== name);
  if (them) { ensureSocialFields(them); them.friendRequests = them.friendRequests.filter(r => r !== currentUser); }
  dbDirty = true;
  await pushDB();
  dbCache = null;
  loadFriendsPanel();
}

async function removeFriend(name) {
  if (!confirm('Remove ' + name + ' as a friend?')) return;
  dbCache = null;
  const users = await fetchDB();
  const me   = users[currentUser];
  const them = users[name];
  if (!me) return;
  ensureSocialFields(me);
  me.friends = me.friends.filter(f => f !== name);
  if (them) { ensureSocialFields(them); them.friends = them.friends.filter(f => f !== currentUser); }
  dbDirty = true;
  await pushDB();
  dbCache = null;
  loadFriendsPanel();
  showToast('Removed ' + name);
}

