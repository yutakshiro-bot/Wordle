<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WORDLE</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&family=Inter:wght@400;700&family=Playfair+Display:wght@400;700&family=Oswald:wght@400;700&family=Raleway:wght@400;700&family=Roboto+Mono:wght@400;700&family=Orbitron:wght@400;700&family=Pacifico&family=Permanent+Marker&family=Josefin+Sans:wght@400;700&family=Abril+Fatface&family=Press+Start+2P&family=Courier+Prime:wght@400;700&family=DM+Serif+Display&family=Cinzel:wght@400;700&family=Righteous&display=swap" rel="stylesheet">
<link id="custom-font-link" rel="stylesheet" href="">
<style>
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
:root {
  --bg:#0f0f0f; --surface:#1a1a1a; --border:#333; --text:#f0ede8;
  --muted:#555; --correct:#538d4e; --present:#b59f3b;
  --absent:#2a2a2a; --absent-text:#555; --key-bg:#2a2a2a;
  --key-text:#f0ede8; --accent:#e8d5b7;
  --ui-font: 'Space Mono', monospace;
}
/* Apply chosen font stably — not a blanket * rule to avoid FOUC / flicker */
body, button, input, textarea, select, label,
.tile, .key, h1, h2, h3, p, div, span, a { font-family: var(--ui-font) !important; }
body.light {
  --bg:#f9f6f1; --surface:#fff; --border:#d0ccc5; --text:#1a1a1a;
  --muted:#999; --absent:#d3d6da; --absent-text:#888; --key-bg:#d3d6da;
  --key-text:#1a1a1a; --accent:#6b5c3e;
}
body { background:var(--bg); color:var(--text); font-family:'Space Mono',monospace; min-height:100vh; display:flex; flex-direction:column; align-items:center; padding:0 16px 40px; overflow-x:hidden; transition:background 0.25s, color 0.25s; }
body.has-bg { background-size:cover !important; background-position:center !important; background-repeat:no-repeat !important; }

/* ── Header ── */
header { width:100%; max-width:640px; padding:14px 4px; border-bottom:1px solid var(--border); margin-bottom:20px; display:flex; align-items:center; justify-content:space-between; position:relative; gap:8px; }
.header-center { text-align:center; position:absolute; left:50%; transform:translateX(-50%); pointer-events:none; }
h1 { font-family:'Bebas Neue',sans-serif; font-size:2.8rem; letter-spacing:0.18em; color:var(--accent); line-height:1; }
.subtitle { font-size:0.55rem; color:var(--muted); letter-spacing:0.25em; text-transform:uppercase; margin-top:2px; }
.byline { font-size:0.5rem; color:var(--muted); letter-spacing:0.15em; margin-top:3px; opacity:0.7; }

/* ── Left nav ── */
.header-nav { display:flex; gap:5px; align-items:center; }
.nav-btn { position:relative; padding:5px 8px; background:transparent; border:1px solid var(--border); color:var(--muted); font-family:'Space Mono',monospace; font-size:0.55rem; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; cursor:pointer; transition:border-color 0.15s, color 0.15s; white-space:nowrap; }
.nav-btn:hover { border-color:var(--accent); color:var(--accent); }
.nav-btn:hover .nav-tip { opacity:1; transform:translateX(-50%) translateY(0); }
.nav-tip { position:absolute; top:calc(100% + 7px); left:50%; transform:translateX(-50%) translateY(-4px); background:var(--surface); border:1px solid var(--border); color:var(--text); font-family:'Space Mono',monospace; font-size:0.5rem; padding:5px 9px; white-space:nowrap; opacity:0; transition:opacity 0.15s, transform 0.15s; z-index:60; pointer-events:none; }
.nav-tip::before { content:''; position:absolute; top:-5px; left:50%; transform:translateX(-50%); border:4px solid transparent; border-bottom-color:var(--border); border-top:none; }

/* ── Auth area ── */
.header-auth { display:flex; gap:7px; align-items:center; }
.btn-ghost { padding:6px 12px; background:transparent; border:1px solid var(--border); color:var(--muted); font-family:'Space Mono',monospace; font-size:0.55rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; cursor:pointer; transition:border-color 0.15s,color 0.15s; }
.btn-ghost:hover { border-color:var(--accent); color:var(--accent); }
.btn-solid { padding:6px 12px; background:var(--correct); border:1px solid var(--correct); color:#fff; font-family:'Space Mono',monospace; font-size:0.55rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; cursor:pointer; transition:filter 0.15s; }
.btn-solid:hover { filter:brightness(1.2); }
#user-chip { display:flex; align-items:center; gap:7px; font-family:'Space Mono',monospace; font-size:0.55rem; color:var(--accent); letter-spacing:0.08em; text-transform:uppercase; }
.avatar { width:26px; height:26px; background:var(--correct); display:flex; align-items:center; justify-content:center; font-family:'Bebas Neue',sans-serif; font-size:0.95rem; color:#fff; }
#btn-logout { background:none; border:none; color:var(--muted); font-family:'Space Mono',monospace; font-size:0.5rem; cursor:pointer; letter-spacing:0.08em; text-transform:uppercase; padding:3px; transition:color 0.15s; }
#btn-logout:hover { color:#e06060; }

/* ── Blitz timer bar ── */
#blitz-bar-wrap { width:min(330px,92vw); height:6px; background:var(--border); margin-bottom:14px; display:none; border-radius:3px; overflow:hidden; }
#blitz-bar-fill { height:100%; width:100%; background:var(--correct); transition:width 1s linear, background 0.5s; border-radius:3px; }
#blitz-timer-text { font-family:'Bebas Neue',sans-serif; font-size:1.6rem; color:var(--accent); letter-spacing:0.12em; margin-bottom:8px; display:none; }

/* ── Grid & Tiles ── */
#grid { display:grid; grid-template-rows:repeat(6,1fr); gap:6px; margin-bottom:24px; width:min(330px, 92vw); transition:width 0.2s; }
.row { display:grid; grid-template-columns:repeat(5,1fr); gap:6px; }
.tile { width:clamp(48px, 13vw, 58px); height:clamp(48px, 13vw, 58px); border:2px solid var(--border); display:flex; align-items:center; justify-content:center; font-family:'Bebas Neue',sans-serif; font-size:clamp(1.5rem, 4.5vw, 2rem); letter-spacing:0.05em; transition:border-color 0.1s; color:var(--text); }
.tile.filled { border-color:#777; animation:pop 0.1s ease; }
.tile.correct { background:var(--correct); border-color:var(--correct); color:#fff; }
.tile.present { background:var(--present); border-color:var(--present); color:#fff; }
.tile.absent  { background:var(--absent);  border-color:var(--absent);  color:var(--absent-text); }
.tile.hint    { background:#2a4a8a; border-color:#2a4a8a; color:#aac4ff; }
.row.shake { animation:shake 0.5s ease; }

/* ── Keyboard ── */
#keyboard { display:flex; flex-direction:column; gap:6px; align-items:center; width:min(500px, 98vw); }
.kb-row { display:flex; gap:5px; }
.key { height:clamp(42px, 11vw, 54px); min-width:clamp(28px, 8vw, 38px); padding:0 6px; background:var(--key-bg); color:var(--key-text); border:none; border-radius:3px; font-family:'Space Mono',monospace; font-size:clamp(0.55rem, 1.8vw, 0.7rem); font-weight:700; cursor:pointer; transition:background 0.15s,color 0.15s,transform 0.08s; text-transform:uppercase; display:flex; align-items:center; justify-content:center; }
.key.wide { min-width:clamp(44px, 12vw, 56px); font-size:clamp(0.45rem, 1.5vw, 0.6rem); }
.key:active { transform:scale(0.94); }
.key.correct { background:var(--correct); color:#fff; }
.key.present { background:var(--present); color:#fff; }
.key.absent  { background:#1a1a1a; color:var(--absent-text); }
body.light .key.absent { background:#787c7e; color:#fff; }
.key.hint-used { background:#2a4a8a; color:#aac4ff; }

/* ── Toast ── */
#toast-container { position:fixed; top:80px; left:50%; transform:translateX(-50%); display:flex; flex-direction:column; gap:8px; align-items:center; z-index:400; pointer-events:none; }
.toast { background:var(--text); color:var(--bg); padding:10px 20px; font-family:'Space Mono',monospace; font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; border-radius:2px; animation:fadeUp 0.3s ease, fadeOut 0.3s ease 1.7s forwards; white-space:nowrap; }

/* ── Keyframes ── */
@keyframes pop     { 0%{transform:scale(1)} 50%{transform:scale(1.08)} 100%{transform:scale(1)} }
@keyframes flipIn  { 0%{transform:rotateX(0)} 50%{transform:rotateX(-90deg)} 100%{transform:rotateX(0)} }
@keyframes bounce  { 0%{transform:translateY(0)} 50%{transform:translateY(-16px)} 100%{transform:translateY(0)} }
@keyframes shake   { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-6px)} 40%{transform:translateX(6px)} 60%{transform:translateX(-4px)} 80%{transform:translateX(4px)} }
@keyframes fadeUp  { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
@keyframes fadeOut { to{opacity:0} }
@keyframes oIn     { from{opacity:0} to{opacity:1} }
@keyframes mUp     { from{transform:translateY(36px) scale(0.96);opacity:0} to{transform:none;opacity:1} }
@keyframes eTile   { from{transform:scale(0.5) rotateY(90deg);opacity:0} to{transform:none;opacity:1} }
@keyframes pulse   { 0%,100%{opacity:1} 50%{opacity:0.4} }

/* ── Overlay / Modal ── */
.overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.8); backdrop-filter:blur(5px); z-index:200; align-items:center; justify-content:center; }
.overlay.show { display:flex; animation:oIn 0.22s ease; }
.modal { background:var(--surface); border:1px solid var(--border); width:min(430px,93vw); padding:30px 28px 26px; display:flex; flex-direction:column; animation:mUp 0.35s cubic-bezier(0.34,1.4,0.64,1); max-height:90vh; overflow-y:auto; }
body:not(.light) .modal { background:#141414; }

/* ── End modal ── */
.end-lbl { font-family:'Space Mono',monospace; font-size:0.58rem; letter-spacing:0.3em; text-transform:uppercase; color:var(--muted); margin-bottom:5px; }
#end-message { font-family:'Bebas Neue',sans-serif; font-size:2.8rem; letter-spacing:0.1em; color:var(--accent); line-height:1; margin-bottom:4px; }
#answer-reveal { font-family:'Space Mono',monospace; font-size:0.72rem; color:var(--muted); letter-spacing:0.15em; text-transform:uppercase; margin-bottom:20px; }
.end-div { width:100%; height:1px; background:var(--border); margin:2px 0 18px; }
#end-word-tiles { display:flex; gap:5px; margin-bottom:18px; flex-wrap:wrap; justify-content:center; max-width:100%; }
.end-tile { width:42px; height:42px; display:flex; align-items:center; justify-content:center; font-family:'Bebas Neue',sans-serif; font-size:1.4rem; font-weight:700; border:2px solid transparent; color:#fff; animation:eTile 0.4s cubic-bezier(0.34,1.4,0.64,1) both; }
.end-tile.correct { background:var(--correct); border-color:var(--correct); }
.end-tile.present { background:var(--present); border-color:var(--present); }
.end-tile.absent  { background:#3a3a3a; border-color:#3a3a3a; color:#888; }
.end-stats { display:flex; gap:10px; width:100%; margin-bottom:18px; }
.stat-box { flex:1; background:rgba(0,0,0,0.12); border:1px solid var(--border); padding:10px 6px; display:flex; flex-direction:column; align-items:center; gap:2px; }
body.light .stat-box { background:rgba(0,0,0,0.04); }
.stat-num { font-family:'Bebas Neue',sans-serif; font-size:1.9rem; color:var(--accent); line-height:1; }
.stat-lbl { font-family:'Space Mono',monospace; font-size:0.48rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--muted); text-align:center; }
#end-time { font-family:'Bebas Neue',sans-serif; font-size:1.5rem; color:var(--text); letter-spacing:0.1em; margin-bottom:18px; }
#end-time span { color:var(--muted); font-size:0.85rem; }
#play-again { width:100%; padding:13px; background:var(--correct); border:none; color:#fff; font-family:'Space Mono',monospace; font-size:0.72rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; cursor:pointer; transition:filter 0.15s,transform 0.1s; }
#play-again:hover { filter:brightness(1.15); transform:translateY(-1px); }

/* ── Menu common ── */
.menu-title { font-family:'Bebas Neue',sans-serif; font-size:1.9rem; letter-spacing:0.1em; color:var(--accent); margin-bottom:18px; }
.menu-div   { width:100%; height:1px; background:var(--border); margin-bottom:18px; }
.menu-close { margin-top:18px; width:100%; padding:11px; background:transparent; border:1px solid var(--border); color:var(--muted); font-family:'Space Mono',monospace; font-size:0.62rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; cursor:pointer; transition:border-color 0.15s,color 0.15s; }
.menu-close:hover { border-color:var(--accent); color:var(--accent); }

/* ── Settings ── */
.srow { display:flex; align-items:flex-start; justify-content:space-between; padding:13px 0; border-bottom:1px solid var(--border); gap:12px; }
.srow:last-child { border-bottom:none; }
.slbl { font-family:'Space Mono',monospace; font-size:0.62rem; letter-spacing:0.1em; text-transform:uppercase; }
.sdesc { font-family:'Space Mono',monospace; font-size:0.5rem; color:var(--muted); margin-top:3px; line-height:1.5; }
.toggle { width:40px; height:22px; background:#2a2a2a; border:1px solid #444; border-radius:11px; cursor:pointer; position:relative; transition:background 0.2s,border-color 0.2s; flex-shrink:0; margin-top:2px; }
body.light .toggle { background:#d0ccc5; border-color:#bbb; }
.toggle.on { background:var(--correct); border-color:var(--correct); }
.toggle::after { content:''; position:absolute; top:3px; left:3px; width:14px; height:14px; background:#fff; border-radius:50%; transition:left 0.2s; }
.toggle.on::after { left:21px; }
/* Colour picker */
.bg-options { display:flex; gap:8px; flex-wrap:wrap; margin-top:10px; align-items:center; }
.bg-swatch { width:28px; height:28px; border:2px solid transparent; cursor:pointer; border-radius:50%; transition:border-color 0.15s, transform 0.1s; }
.bg-swatch:hover, .bg-swatch.active { border-color:var(--accent); transform:scale(1.1); }
.bg-swatch.clear { background: conic-gradient(#f00,#ff0,#0f0,#0ff,#00f,#f0f,#f00); }
.bg-upload-btn { padding:5px 10px; background:transparent; border:1px solid var(--border); color:var(--muted); font-family:'Space Mono',monospace; font-size:0.5rem; cursor:pointer; letter-spacing:0.08em; text-transform:uppercase; transition:border-color 0.15s,color 0.15s; }
.bg-upload-btn:hover { border-color:var(--accent); color:var(--accent); }
#bg-color-input { width:40px; height:28px; border:1px solid var(--border); padding:0; cursor:pointer; background:none; }
#bg-reset-btn { padding:5px 10px; background:transparent; border:1px solid #e06060; color:#e06060; font-family:'Space Mono',monospace; font-size:0.5rem; cursor:pointer; letter-spacing:0.08em; text-transform:uppercase; }
#bg-reset-btn:hover { background:#e06060; color:#fff; }

/* ── Gamemodes ── */
.gcard { border:1px solid var(--border); padding:14px; margin-bottom:8px; display:flex; align-items:center; gap:12px; cursor:pointer; transition:border-color 0.15s, background 0.15s; }
.gcard:hover { border-color:var(--accent); }
.gcard.active { border-color:var(--correct); background:rgba(83,141,78,0.08); }
.gcard-icon { font-size:1.3rem; }
.gcard-name { font-family:'Bebas Neue',sans-serif; font-size:1.2rem; letter-spacing:0.1em; }
.gcard-desc { font-family:'Space Mono',monospace; font-size:0.52rem; color:var(--muted); margin-top:2px; }
.gcard-badge { margin-left:auto; background:var(--correct); color:#fff; font-family:'Space Mono',monospace; font-size:0.48rem; padding:3px 7px; letter-spacing:0.08em; text-transform:uppercase; flex-shrink:0; }

/* ── Leaderboard ── */
/* ── Leaderboard redesign ── */
.lb-header-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
.lb-refresh-btn { background:none; border:1px solid var(--border); color:var(--muted); font-family:'Space Mono',monospace; font-size:0.48rem; padding:5px 11px; cursor:pointer; letter-spacing:0.1em; text-transform:uppercase; transition:all 0.15s; border-radius:2px; }
.lb-refresh-btn:hover { border-color:var(--accent); color:var(--accent); }
.lb-last-updated { font-family:'Space Mono',monospace; font-size:0.44rem; color:var(--muted); letter-spacing:0.08em; }
.lb-tab-group { margin-bottom:10px; }
.lb-tab-label { font-family:'Space Mono',monospace; font-size:0.44rem; color:var(--muted); letter-spacing:0.2em; text-transform:uppercase; margin-bottom:5px; padding-left:2px; }
.lb-tabs { display:flex; gap:0; border-bottom:1px solid var(--border); margin-bottom:0; }
.lb-tab { flex:1; padding:7px 4px; background:none; border:none; border-bottom:2px solid transparent; color:var(--muted); font-family:'Space Mono',monospace; font-size:0.5rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; cursor:pointer; transition:color 0.15s,border-color 0.15s; margin-bottom:-1px; }
.lb-tab.active { color:var(--accent); border-bottom-color:var(--accent); }
.lb-row-tabs { display:flex; gap:5px; margin:10px 0 12px; }
.lb-row-tab { flex:1; padding:6px 4px; background:transparent; border:1px solid var(--border); color:var(--muted); font-family:'Space Mono',monospace; font-size:0.48rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; cursor:pointer; transition:all 0.15s; border-radius:2px; }
.lb-row-tab.active { border-color:var(--accent); color:var(--accent); background:rgba(232,213,183,0.07); }
.lb-row-tab:hover:not(.active) { border-color:var(--muted); color:var(--text); }
#lb-list { max-height:260px; overflow-y:auto; scrollbar-width:thin; scrollbar-color:var(--border) transparent; }
#lb-list::-webkit-scrollbar { width:3px; }
#lb-list::-webkit-scrollbar-track { background:transparent; }
#lb-list::-webkit-scrollbar-thumb { background:var(--border); border-radius:2px; }
.lb-row { display:flex; align-items:center; gap:10px; padding:9px 6px; border-radius:3px; transition:background 0.1s; }
.lb-row:hover { background:rgba(255,255,255,0.03); }
.lb-row.lb-row-you { background:rgba(83,141,78,0.08); border-left:2px solid var(--correct); padding-left:4px; }
.lb-rank { font-family:'Bebas Neue',sans-serif; font-size:1.5rem; color:var(--muted); width:30px; text-align:center; flex-shrink:0; line-height:1; }
.lb-rank.gold   { color:#ffd700; }
.lb-rank.silver { color:#c0c0c0; }
.lb-rank.bronze { color:#cd7f32; }
.lb-avatar { width:22px; height:22px; background:var(--border); display:flex; align-items:center; justify-content:center; font-family:'Bebas Neue',sans-serif; font-size:0.8rem; color:var(--text); flex-shrink:0; border-radius:2px; }
.lb-avatar.you { background:var(--correct); color:#fff; }
.lb-info { flex:1; min-width:0; }
.lb-name { font-family:'Space Mono',monospace; font-size:0.6rem; font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.lb-name.you { color:var(--correct); }
.lb-score-col { display:flex; flex-direction:column; align-items:flex-end; flex-shrink:0; }
.lb-score { font-family:'Bebas Neue',sans-serif; font-size:1.6rem; color:var(--accent); line-height:1; }
.lb-score-lbl { font-family:'Space Mono',monospace; font-size:0.38rem; color:var(--muted); letter-spacing:0.12em; text-transform:uppercase; }
.lb-empty { font-family:'Space Mono',monospace; font-size:0.6rem; color:var(--muted); text-align:center; padding:28px 0; letter-spacing:0.1em; }
.lb-divider { height:1px; background:var(--border); margin:0 6px; opacity:0.5; }
@keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
.spinning { animation:spin 0.7s linear; display:inline-block; }

/* ── Auth modal ── */
.auth-tabs { display:flex; margin-bottom:24px; border-bottom:1px solid var(--border); }
.auth-tab { flex:1; padding:9px; background:none; border:none; border-bottom:2px solid transparent; color:var(--muted); font-family:'Space Mono',monospace; font-size:0.62rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; cursor:pointer; transition:color 0.15s,border-color 0.15s; margin-bottom:-1px; }
.auth-tab.active { color:var(--accent); border-bottom-color:var(--accent); }
.afield { display:flex; flex-direction:column; gap:5px; margin-bottom:14px; }
.albl { font-family:'Space Mono',monospace; font-size:0.52rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--muted); }
.ainput { background:var(--bg); border:1px solid var(--border); color:var(--text); padding:10px 13px; font-family:'Space Mono',monospace; font-size:0.72rem; outline:none; width:100%; transition:border-color 0.15s; }
.ainput:focus { border-color:var(--accent); }
.aerr { font-family:'Space Mono',monospace; font-size:0.55rem; color:#e06060; min-height:15px; margin-bottom:3px; }
.asubmit { width:100%; padding:12px; background:var(--correct); border:none; color:#fff; font-family:'Space Mono',monospace; font-size:0.68rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; cursor:pointer; transition:filter 0.15s; margin-top:3px; }
.asubmit:hover { filter:brightness(1.15); }
.pw-bar { height:3px; background:var(--border); margin-top:5px; }
.pw-fill { height:100%; width:0%; transition:width 0.3s,background 0.3s; }
.pw-reqs { display:flex; flex-direction:column; gap:3px; margin-top:5px; margin-bottom:10px; }
.pw-req { font-family:'Space Mono',monospace; font-size:0.5rem; color:var(--muted); display:flex; align-items:center; gap:5px; transition:color 0.2s; }
.pw-req.met { color:var(--correct); }
.pw-req::before { content:'○'; font-size:0.58rem; }
.pw-req.met::before { content:'●'; }

.font-btn { padding:6px 12px; background:transparent; border:1px solid var(--border); color:var(--muted); font-family:'Space Mono',monospace; font-size:0.55rem; cursor:pointer; letter-spacing:0.08em; text-transform:uppercase; transition:all 0.15s; }
