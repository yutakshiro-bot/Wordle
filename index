  renderLeaderboard();
}

function getTimePeriodKey(baseKey, time) {
  if (time === 'alltime') return baseKey;
  const now = new Date();
  if (time === 'weekly') {
    const week = `${now.getFullYear()}_w${Math.ceil((now.getDate() + new Date(now.getFullYear(), now.getMonth(), 1).getDay()) / 7)}_${now.getMonth()}`;
    return baseKey + '_w_' + week;
  }
  if (time === 'monthly') {
    return baseKey + '_m_' + now.getFullYear() + '_' + now.getMonth();
  }
  return baseKey;
}

let lbRenderToken = 0;

async function renderLeaderboard() {
  const token = ++lbRenderToken;
  const list = document.getElementById('lb-list');
  list.innerHTML = '<div class="lb-empty">Loading…</div>';
  const users = await fetchDB();
  if (token !== lbRenderToken) return; // stale render — a newer one is in flight
  const mode = currentLbMode;
  const type = currentLbType;
  const time = currentLbTime;

  let baseKey, scoreLabel, icon;
  if (type === 'streak') {
    baseKey = mode === 'classic' ? 'bestStreak' : mode === 'blitz' ? 'blitzBest' : 'easyBest';
    scoreLabel = 'streak'; icon = '🔥';
  } else {
    baseKey = mode === 'classic' ? 'totalWins' : mode === 'blitz' ? 'blitzWins' : 'easyWins';
    scoreLabel = 'wins'; icon = '🏆';
  }
  const scoreKey = getTimePeriodKey(baseKey, time);

  const entries = Object.entries(users)
    .map(([name, data]) => ({ name, score: data[scoreKey] || 0, initial: name[0].toUpperCase() }))
    .filter(e => e.score > 0)
    .sort((a, b) => b.score - a.score)
    .slice(0, 20);

  // Update last-updated timestamp
  const lu = document.getElementById('lb-last-updated');
  if (lu) lu.textContent = 'Updated ' + new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});

  if (entries.length === 0) {
    const periodLabel = time === 'weekly' ? 'this week' : time === 'monthly' ? 'this month' : 'yet';
    list.innerHTML = `<div class="lb-empty">No scores ${periodLabel} — play to appear here!</div>`;
    return;
  }

  const rankClasses = ['gold','silver','bronze'];
  // Build pfp map from DB records (cross-device sync)
  const pfpMap = {};
  Object.entries(users).forEach(([name, data]) => {
    if (data && data.prefs && data.prefs.pfp && data.prefs.pfp !== '__toobig__') {
      pfpMap[name] = data.prefs.pfp;
      // Cache in localStorage so leaderboard renders fast next time
      try { localStorage.setItem('wordleProfilePhoto_' + name, data.prefs.pfp); } catch {}
    } else {
      // Fall back to local cache (e.g. for the current user's own device)
      const local = localStorage.getItem('wordleProfilePhoto_' + name);
      if (local) pfpMap[name] = local;
    }
  });

  list.innerHTML = entries.map((e, i) => {
    const isYou = e.name === currentUser;
    const photo = pfpMap[e.name];
    const avatarHtml = photo
      ? `<div class="lb-avatar${isYou ? ' you' : ''}" style="background:none;padding:0;overflow:hidden;border-radius:3px;"><img src="${photo}" style="width:100%;height:100%;object-fit:cover;" /></div>`
      : `<div class="lb-avatar${isYou ? ' you' : ''}">${e.initial}</div>`;
    return `<div class="lb-row${isYou ? ' lb-row-you' : ''}">
      <div class="lb-rank ${rankClasses[i] || ''}">${i < 3 ? ['①','②','③'][i] : i + 1}</div>
      ${avatarHtml}
      <div class="lb-info"><div class="lb-name${isYou ? ' you' : ''}">${e.name}${isYou ? ' ✦' : ''}</div></div>
      <div class="lb-score-col"><div class="lb-score">${e.score}</div><div class="lb-score-lbl">${scoreLabel}</div></div>
    </div>
    ${i < entries.length - 1 ? '<div class="lb-divider"></div>' : ''}`;
  }).join('');
}

