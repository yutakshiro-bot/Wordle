/* ── Font Cards ── */
.font-card { background:var(--bg); border:1px solid var(--border); padding:10px 10px 8px; cursor:pointer; transition:border-color 0.15s, background 0.15s; text-align:left; display:flex; flex-direction:column; gap:3px; }
.font-card:hover { border-color:var(--accent); }
.font-card.active { border-color:var(--correct); background:rgba(83,141,78,0.08); }
.font-card-name { font-size:0.55rem; font-weight:700; letter-spacing:0.06em; color:var(--text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.font-card-tag  { font-size:0.42rem; color:var(--muted); letter-spacing:0.12em; text-transform:uppercase; }
.font-card-preview { font-size:1.1rem; color:var(--accent); line-height:1.2; margin-top:2px; }
#setup-banner .sb-title { font-family:'Bebas Neue',sans-serif; font-size:1.1rem; color:#b59f3b; letter-spacing:0.1em; flex-shrink:0; margin-top:1px; }
#setup-banner .sb-steps { font-family:'Space Mono',monospace; font-size:0.55rem; color:#aaa; line-height:1.9; flex:1; min-width:200px; }
#setup-banner .sb-steps a { color:#b59f3b; }
#setup-banner .sb-close { background:none; border:1px solid #555; color:#888; font-family:'Space Mono',monospace; font-size:0.5rem; padding:5px 10px; cursor:pointer; letter-spacing:0.1em; flex-shrink:0; margin-top:2px; }
#setup-banner .sb-close:hover { border-color:#b59f3b; color:#b59f3b; }
/* ── Friends & Messaging ── */
.fr-tabs { display:flex; border-bottom:1px solid var(--border); margin-bottom:14px; }
.fr-tab { flex:1; padding:8px 4px; background:none; border:none; border-bottom:2px solid transparent; color:var(--muted); font-size:0.52rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; cursor:pointer; transition:color 0.15s,border-color 0.15s; margin-bottom:-1px; }
.fr-tab.active { color:var(--accent); border-bottom-color:var(--accent); }
.fr-tab .fr-tab-badge { display:inline-block; background:#e06060; color:#fff; border-radius:8px; font-size:0.42rem; padding:1px 5px; margin-left:4px; vertical-align:middle; }
.fr-search-row { display:flex; gap:7px; margin-bottom:14px; }
.fr-search-row .ainput { flex:1; font-size:0.65rem; }
.fr-add-btn { padding:8px 14px; background:var(--correct); border:none; color:#fff; font-size:0.55rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; cursor:pointer; white-space:nowrap; transition:filter 0.15s; }
.fr-add-btn:hover { filter:brightness(1.15); }
.fr-list { display:flex; flex-direction:column; gap:6px; max-height:320px; overflow-y:auto; scrollbar-width:thin; scrollbar-color:var(--border) transparent; }
.fr-row { display:flex; align-items:center; gap:10px; padding:9px 10px; border:1px solid var(--border); border-radius:3px; transition:border-color 0.12s; }
.fr-row:hover { border-color:var(--accent); }
.fr-avatar { width:34px; height:34px; background:var(--correct); display:flex; align-items:center; justify-content:center; border-radius:3px; font-size:1rem; color:#fff; flex-shrink:0; overflow:hidden; }
.fr-avatar img { width:100%; height:100%; object-fit:cover; }
.fr-info { flex:1; min-width:0; }
.fr-name { font-size:0.6rem; font-weight:700; letter-spacing:0.06em; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.fr-sub  { font-size:0.46rem; color:var(--muted); margin-top:1px; letter-spacing:0.06em; }
.fr-actions { display:flex; gap:5px; flex-shrink:0; }
.fr-btn { padding:5px 10px; border:1px solid var(--border); background:transparent; color:var(--muted); font-size:0.48rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; cursor:pointer; transition:all 0.15s; border-radius:2px; }
.fr-btn:hover { border-color:var(--accent); color:var(--accent); }
.fr-btn.accept { border-color:var(--correct); color:var(--correct); }
