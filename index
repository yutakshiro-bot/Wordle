// ══════════════════════════════════════════════
// GLOBAL FONT SYSTEM
// ══════════════════════════════════════════════
const FONT_PRESETS = [
  { id:'space-mono',   label:'Space Mono',       family:"'Space Mono', monospace",        tag:'Default' },
  { id:'inter',        label:'Inter',             family:"'Inter', sans-serif",             tag:'Clean' },
  { id:'bebas',        label:'Bebas Neue',        family:"'Bebas Neue', sans-serif",        tag:'Bold' },
  { id:'playfair',     label:'Playfair Display',  family:"'Playfair Display', serif",       tag:'Elegant' },
  { id:'oswald',       label:'Oswald',            family:"'Oswald', sans-serif",            tag:'Condensed' },
  { id:'raleway',      label:'Raleway',           family:"'Raleway', sans-serif",           tag:'Modern' },
  { id:'roboto-mono',  label:'Roboto Mono',       family:"'Roboto Mono', monospace",        tag:'Code' },
  { id:'orbitron',     label:'Orbitron',          family:"'Orbitron', sans-serif",          tag:'Sci-Fi' },
  { id:'pacifico',     label:'Pacifico',          family:"'Pacifico', cursive",             tag:'Fun' },
  { id:'perm-marker',  label:'Permanent Marker',  family:"'Permanent Marker', cursive",     tag:'Handwritten' },
  { id:'josefin',      label:'Josefin Sans',      family:"'Josefin Sans', sans-serif",      tag:'Geometric' },
  { id:'abril',        label:'Abril Fatface',     family:"'Abril Fatface', serif",          tag:'Display' },
  { id:'press-start',  label:'Press Start 2P',    family:"'Press Start 2P', monospace",     tag:'Retro' },
  { id:'courier',      label:'Courier Prime',     family:"'Courier Prime', monospace",      tag:'Typewriter' },
  { id:'dm-serif',     label:'DM Serif Display',  family:"'DM Serif Display', serif",       tag:'Serif' },
  { id:'cinzel',       label:'Cinzel',            family:"'Cinzel', serif",                 tag:'Classic' },
  { id:'righteous',    label:'Righteous',         family:"'Righteous', sans-serif",         tag:'Rounded' },
];

let currentFontId = 'space-mono';

function buildFontGrid() {
  const grid = document.getElementById('font-grid');
  if (!grid) return;
  grid.innerHTML = FONT_PRESETS.map(f => `
    <button class="font-card${f.id === currentFontId ? ' active' : ''}" id="fcard-${f.id}" onclick="applyGlobalFont('${f.id}')" style="font-family:${f.family};">
      <div class="font-card-name">${f.label}</div>
      <div class="font-card-tag">${f.tag}</div>
      <div class="font-card-preview" style="font-family:${f.family};">Aa Bb</div>
    </button>
  `).join('');
}

function applyGlobalFont(id, customFamily, customLabel) {
  const preset = FONT_PRESETS.find(f => f.id === id);
  const family = customFamily || (preset ? preset.family : "'Space Mono', monospace");
  const label  = customLabel  || (preset ? preset.label  : 'Custom');

  currentFontId = id;
  // One line — CSS variable does ALL the work via * { font-family: var(--ui-font) !important }
  document.documentElement.style.setProperty('--ui-font', family);

  // Update grid selection highlight
  document.querySelectorAll('.font-card').forEach(el => el.classList.remove('active'));
  const card = document.getElementById('fcard-' + id);
  if (card) card.classList.add('active');

  localStorage.setItem('wordleGlobalFont', JSON.stringify({ id, family, label }));

  const status = document.getElementById('custom-font-status');
  if (status && (id === 'custom-url' || id === 'custom-upload')) {
    status.textContent = '✓ ' + label + ' applied!';
    status.style.color = 'var(--correct)';
  }

  // Sync to cloud if logged in
  if (currentUser) syncPrefsToCloud();
}

function applyCustomFontUrl() {
  const urlInput = document.getElementById('custom-font-url');
  const status = document.getElementById('custom-font-status');
  let url = urlInput.value.trim();
  if (!url) { status.textContent = 'Please paste a Google Fonts URL.'; status.style.color='#e06060'; return; }

  // Accept both full embed URLs and bare family names
  let fontName = 'Custom Font';
  try {
    // Extract family name from URL like ?family=Lobster or ?family=Lobster+Two
    const match = url.match(/family=([^&:]+)/);
    if (match) fontName = decodeURIComponent(match[1]).replace(/\+/g,' ').split(':')[0].split(';')[0].trim();
  } catch {}

  // If they typed just a font name (no http), build the URL
  if (!url.startsWith('http')) {
    fontName = url;
    url = 'https://fonts.googleapis.com/css2?family=' + encodeURIComponent(url.replace(/ /g, '+')) + ':wght@400;700&display=swap';
  }

  status.textContent = 'Loading…'; status.style.color = 'var(--muted)';
  const link = document.getElementById('custom-font-link');
  link.href = url;
  link.onload = () => {
    const family = `'${fontName}', sans-serif`;
    // Remove old custom preset if any
    const existing = FONT_PRESETS.findIndex(f => f.id === 'custom-url');
    const entry = { id:'custom-url', label:fontName, family, tag:'Custom' };
    if (existing >= 0) FONT_PRESETS[existing] = entry; else FONT_PRESETS.push(entry);
    buildFontGrid();
    applyGlobalFont('custom-url', family, fontName);
  };
  link.onerror = () => { status.textContent = 'Failed to load font — check the URL.'; status.style.color='#e06060'; };
}

function applyUploadedFont(input) {
  const file = input.files[0];
  if (!file) return;
  const status = document.getElementById('custom-font-status');
  status.textContent = 'Loading…'; status.style.color = 'var(--muted)';
  const reader = new FileReader();
  reader.onload = e => {
    const fontName = file.name.replace(/\.[^.]+$/, '').replace(/[-_]/g,' ');
    const dataUrl = e.target.result;
    // Inject @font-face
    let styleEl = document.getElementById('uploaded-font-style');
    if (!styleEl) { styleEl = document.createElement('style'); styleEl.id = 'uploaded-font-style'; document.head.appendChild(styleEl); }
    styleEl.textContent = `@font-face { font-family: '${fontName}'; src: url('${dataUrl}'); }`;
    const family = `'${fontName}', sans-serif`;
    const existing = FONT_PRESETS.findIndex(f => f.id === 'custom-upload');
    const entry = { id:'custom-upload', label:fontName, family, tag:'Uploaded' };
    if (existing >= 0) FONT_PRESETS[existing] = entry; else FONT_PRESETS.push(entry);
    buildFontGrid();
    applyGlobalFont('custom-upload', family, fontName);
    // Don't save dataUrl to localStorage (too large) — just save name
    localStorage.setItem('wordleGlobalFont', JSON.stringify({ id:'custom-upload', family, label:fontName }));
  };
  reader.readAsDataURL(file);
}

function resetGlobalFont() {
  currentFontId = 'space-mono';
  document.documentElement.style.setProperty('--ui-font', "'Space Mono', monospace");
  localStorage.removeItem('wordleGlobalFont');
  buildFontGrid();
  const status = document.getElementById('custom-font-status');
  if (status) { status.textContent = 'Font reset to default.'; status.style.color='var(--muted)'; }
  const urlInput = document.getElementById('custom-font-url');
  if (urlInput) urlInput.value = '';
  if (currentUser) syncPrefsToCloud();
}

function loadCustomizations() {
  const colors = JSON.parse(localStorage.getItem('wordleColors') || '{}');
  if (colors.correct) { document.documentElement.style.setProperty('--correct', colors.correct); document.getElementById('color-correct').value = colors.correct; }
  if (colors.present) { document.documentElement.style.setProperty('--present', colors.present); document.getElementById('color-present').value = colors.present; }
  if (colors.absent)  { document.documentElement.style.setProperty('--absent',  colors.absent);  document.getElementById('color-absent').value  = colors.absent; }

  // Restore saved global font
  const savedFont = JSON.parse(localStorage.getItem('wordleGlobalFont') || 'null');
  if (savedFont) {
    setTimeout(() => {
      if (savedFont.id === 'custom-url' || savedFont.id === 'custom-upload') {
        const existing = FONT_PRESETS.findIndex(f => f.id === savedFont.id);
        const entry = { id:savedFont.id, label:savedFont.label, family:savedFont.family, tag: savedFont.id === 'custom-url' ? 'Custom' : 'Uploaded' };
        if (existing >= 0) FONT_PRESETS[existing] = entry; else FONT_PRESETS.push(entry);
      }
      applyGlobalFont(savedFont.id, savedFont.family, savedFont.label);
    }, 200);
  }
}

function loadSettings() {
  if (localStorage.getItem('wordleLight')) {
    document.body.classList.add('light');
    const el = document.getElementById('toggle-light');
    if (el) el.classList.add('on');
  }
  const bg = JSON.parse(localStorage.getItem('wordleBg') || 'null');
  if (bg) {
    if (bg.type === 'color') { document.body.style.backgroundColor = bg.value; document.body.classList.add('has-bg'); document.getElementById('bg-color-input').value = bg.value; }
    else if (bg.type === 'image') { document.body.style.backgroundImage = `url(${bg.value})`; document.body.classList.add('has-bg'); }
  }
}

