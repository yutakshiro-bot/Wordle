async function openDM(partner) {
  currentDMUser = partner;
  // Set header
  document.getElementById('dm-title').textContent = partner;
  // Avatar
  const avatarEl = document.getElementById('dm-avatar');
  const pfp = localStorage.getItem('wordleProfilePhoto_' + partner);
  avatarEl.innerHTML = pfp ? `<img src="${pfp}" />` : partner[0].toUpperCase();
  avatarEl.style.background = pfp ? 'none' : 'var(--correct)';

  openOverlay('dm-overlay');
  await renderDMMessages();
  // Mark messages from partner as read
  await markMessagesRead(partner);
  // Poll for new messages every 6s
  clearInterval(dmPollInterval);
  dmPollInterval = setInterval(async () => {
    if (currentDMUser === partner && document.getElementById('dm-overlay').classList.contains('show')) {
      await renderDMMessages();
      await markMessagesRead(partner);
    } else {
      clearInterval(dmPollInterval);
    }
  }, 6000);
}

function closeDM() {
  clearInterval(dmPollInterval);
  dmPollInterval = null;
  currentDMUser = null;
  closeOverlay('dm-overlay');
  // Return to friends panel
  openFriends();
}

async function renderDMMessages() {
  const msgsEl = document.getElementById('dm-msgs');
  if (!msgsEl) return;
  dbCache = null;
  const users = await fetchDB();
  _lastUsersForStatus = users;
  const me = users[currentUser];
  if (!me) return;
  ensureSocialFields(me);
  const partner = currentDMUser;

  // Update status in DM header
  const cls = _statusClassFromCache(partner);
  const subEl = document.getElementById('dm-sub');
  if (subEl) subEl.textContent = _statusLabel(cls);

  const convo = (me.messages[partner] || []).slice(-100);

  if (convo.length === 0) {
    msgsEl.innerHTML = `<div class="fr-empty" style="margin:auto;">No messages yet — say hi! 👋</div>`;
    return;
  }

  // Check what partner has read
  const themUser = users[partner];
  const theirConvo = themUser ? ((themUser.messages || {})[currentUser] || []) : [];
  const readByPartner = new Set(theirConvo.filter(m => m.from === currentUser && m.read).map(m => m.ts));

  const wasAtBottom = msgsEl.scrollHeight - msgsEl.scrollTop - msgsEl.clientHeight < 80;

  let html = '';
  let lastDate = '';
  convo.forEach((msg, idx) => {
    const isMe = msg.from === currentUser;
    const d = new Date(msg.ts);
    const dateStr = d.toLocaleDateString([], { weekday:'short', month:'short', day:'numeric' });
    if (dateStr !== lastDate) {
      html += `<div class="dm-date-divider">${dateStr}</div>`;
      lastDate = dateStr;
    }
    const timeStr = d.toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' });

    // Reply quote
    let replyQuoteHtml = '';
    if (msg.replyTo) {
      const quoted = convo.find(m => m.ts === msg.replyTo) || {};
      const quotedText = quoted.text ? (quoted.text.startsWith('__IMG__') ? '🖼 Image' : esc(quoted.text.slice(0,60) + (quoted.text.length>60?'…':''))) : '…';
      replyQuoteHtml = `<div class="dm-reply-quote" onclick="scrollToMsg(${msg.replyTo})">↩ ${esc(quoted.from||'')}: ${quotedText}</div>`;
    }

    // Bubble content
    let bubbleContent;
    if (msg.text && msg.text.startsWith('__IMG__')) {
      bubbleContent = `<img class="dm-img" src="${msg.text.slice(7)}" onclick="openLightbox(this.src)" loading="lazy">`;
    } else {
      bubbleContent = `<div class="dm-bubble">${esc(msg.text || '')}</div>`;
    }

    // Read receipt
    let receipt = '';
    if (isMe) {
      const isLastFromMe = !convo.slice(idx+1).some(m => m.from === currentUser);
      if (isLastFromMe) {
        const wasRead = readByPartner.has(msg.ts);
        receipt = `<div class="dm-receipt ${wasRead ? 'read' : ''}">${wasRead ? '✓✓ Read' : '✓ Delivered'}</div>`;
      }
    }

    // Reactions
    let reactionsHtml = '';
    if (msg.reactions && Object.keys(msg.reactions).length > 0) {
      // Aggregate: { emoji: [usernames] }
      const agg = {};
      Object.entries(msg.reactions).forEach(([user, emoji]) => {
        if (!agg[emoji]) agg[emoji] = [];
        agg[emoji].push(user);
      });
      reactionsHtml = '<div class="dm-reactions">' +
        Object.entries(agg).map(([emoji, users]) => {
          const mine = users.includes(currentUser);
          const tip = users.slice(0,3).join(', ') + (users.length>3 ? ` +${users.length-3}` : '');
          return `<span class="dm-reaction${mine?' mine':''}" onclick="toggleReaction(${msg.ts},'${emoji}')" title="${tip}">${emoji}<span class="dm-reaction-count">${users.length}</span></span>`;
        }).join('') + '</div>';
    }

    // Action toolbar (reply + react)
    const quickEmoji = ['❤️','😂','👍','😮','😢','🔥'].map(e =>
      `<button class="dm-action-btn" onclick="toggleReaction(${msg.ts},'${e}')" title="${e}">${e}</button>`
    ).join('');
    const actionsHtml = `<div class="dm-bubble-actions">
      ${quickEmoji}
      <button class="dm-action-btn" onclick="startReply(${msg.ts},'${esc(msg.from)}','${(msg.text||'').startsWith('__IMG__')?'🖼 Image':esc((msg.text||'').slice(0,40))}')" title="Reply">↩</button>
    </div>`;

    html += `<div class="dm-bubble-wrap ${isMe ? 'me' : 'them'}" data-msg-ts="${msg.ts}">
      <div class="dm-bubble-outer">
        ${actionsHtml}
        ${replyQuoteHtml}
        ${bubbleContent}
      </div>
      <div class="dm-ts">${timeStr}</div>
      ${receipt}
      ${reactionsHtml}
    </div>`;
  });

  msgsEl.innerHTML = html;
  if (wasAtBottom) msgsEl.scrollTop = msgsEl.scrollHeight;
}

// ── Message send queue — prevents race conditions & simultaneous message bugs ──
let _dmSendQueue = Promise.resolve();
let _dmSending = false;
let _pendingReplyTs = null; // ts of message being replied to

async function sendDM() {
  const input = document.getElementById('dm-input');
  const text = input.value.trim();
  if (!text || !currentDMUser) return;
  input.value = '';
  _queueMessage(text);
}

async function sendImageDM(fileInput) {
  const file = fileInput.files[0];
  if (!file || !currentDMUser) return;
  fileInput.value = '';
  if (file.size > 8000000) { showToast('Image too large — max 8MB'); return; }

  showToast('Compressing image…');
  try {
    const compressed = await _compressImage(file, 320, 240, 0.7);
    // Check compressed size — JSONBin has a 5MB bin limit, keep messages small
    if (compressed.length > 180000) {
      showToast('Image still too large after compression — try a smaller image');
      return;
    }
    _queueMessage('__IMG__' + compressed);
  } catch(e) {
    showToast('Could not process image');
    console.error(e);
  }
}

function _compressImage(file, maxW, maxH, quality) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onerror = reject;
    reader.onload = ev => {
      const img = new Image();
      img.onerror = reject;
      img.onload = () => {
        const canvas = document.createElement('canvas');
        let w = img.width, h = img.height;
        // Scale down proportionally
        if (w > maxW || h > maxH) {
          const ratio = Math.min(maxW / w, maxH / h);
          w = Math.round(w * ratio);
          h = Math.round(h * ratio);
        }
        canvas.width = w;
        canvas.height = h;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0, w, h);
        resolve(canvas.toDataURL('image/jpeg', quality));
      };
      img.src = ev.target.result;
    };
    reader.readAsDataURL(file);
  });
}

function _queueMessage(text) {
  const partner = currentDMUser;
  const ts = Date.now() + Math.random(); // tiny jitter prevents exact collisions
  const tsInt = Math.round(ts);
  // Optimistic display
  _showOptimisticBubble(text, tsInt);
  // Chain onto queue — guarantees serial execution
  _dmSendQueue = _dmSendQueue.then(() => _atomicSendMessage(partner, text, tsInt));
  // Clear reply state after queueing
  _pendingReplyTs = null;
  cancelReply();
}

function _showOptimisticBubble(text, ts) {
  const msgsEl = document.getElementById('dm-msgs');
  if (!msgsEl) return;
  const empty = msgsEl.querySelector('.fr-empty');
  if (empty) empty.remove();
  const timeStr = new Date(ts).toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' });
  const isImg = text.startsWith('__IMG__');

  // Reply quote for optimistic bubble
  let replyQuoteHtml = '';
  if (_pendingReplyTs) {
    const allWraps = msgsEl.querySelectorAll('[data-msg-ts]');
    let quotedText = '…';
    allWraps.forEach(w => { if (w.dataset.msgTs == _pendingReplyTs) {
      const bub = w.querySelector('.dm-bubble');
      quotedText = bub ? bub.textContent.slice(0,50) : '🖼 Image';
    }});
    replyQuoteHtml = `<div class="dm-reply-quote">↩ ${quotedText}</div>`;
  }

  const bubbleContent = isImg
    ? `<img class="dm-img" src="${text.slice(7)}" style="opacity:0.6" onclick="openLightbox(this.src)">`
    : `<div class="dm-bubble" style="opacity:0.75">${esc(text)}</div>`;

  const wrap = document.createElement('div');
  wrap.className = 'dm-bubble-wrap me';
  wrap.dataset.optTs = ts;
  wrap.innerHTML = `<div class="dm-bubble-outer">${replyQuoteHtml}${bubbleContent}</div><div class="dm-ts">${timeStr}</div><div class="dm-receipt">⏳ Sending…</div>`;
  msgsEl.appendChild(wrap);
  msgsEl.scrollTop = msgsEl.scrollHeight;
}

async function _atomicSendMessage(partner, text, ts) {
  for (let attempt = 0; attempt < 4; attempt++) {
    try {
      dbCache = null;
      const users = await fetchDB();
      const me = users[currentUser];
      const them = users[partner];
      if (!me || !them) { showToast('Could not send — user not found'); _markOptimisticFailed(ts); return; }
      ensureSocialFields(me);
      ensureSocialFields(them);

      // Idempotent: skip if already added (handles retries)
      const myConvo = me.messages[partner] = me.messages[partner] || [];
      const theirConvo = them.messages[currentUser] = them.messages[currentUser] || [];
      const alreadyMe = myConvo.some(m => m.ts === ts && m.from === currentUser);
      const alreadyThem = theirConvo.some(m => m.ts === ts && m.from === currentUser);

      if (!alreadyMe) {
        const msgObj = { from:currentUser, text, ts, read:true };
        if (_pendingReplyTs) msgObj.replyTo = _pendingReplyTs;
        myConvo.push(msgObj);
        if (myConvo.length > 200) me.messages[partner] = myConvo.slice(-200);
      }
      if (!alreadyThem) {
        const msgObj2 = { from:currentUser, text, ts, read:false };
        if (_pendingReplyTs) msgObj2.replyTo = _pendingReplyTs;
        theirConvo.push(msgObj2);
        if (theirConvo.length > 200) them.messages[currentUser] = theirConvo.slice(-200);
      }

      dbDirty = true;
      await pushDB();
      dbCache = null;
      // Replace optimistic bubbles with real render
      await renderDMMessages();
      return;
    } catch(e) {
      if (attempt < 3) {
        await new Promise(r => setTimeout(r, 300 * (attempt + 1)));
      } else {
        showToast('Message failed — check your connection');
        _markOptimisticFailed(ts);
      }
    }
  }
}

function _markOptimisticFailed(ts) {
  const el = document.querySelector(`.dm-bubble-wrap[data-opt-ts="${ts}"] .dm-receipt`);
  if (el) { el.textContent = '✗ Failed'; el.style.color = '#e06060'; }
}

