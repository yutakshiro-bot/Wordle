let dinoState = null, dinoRAF = null;
function initDino() {
  const canvas = document.getElementById('dino-canvas');
  if (!canvas) return;
  canvas.addEventListener('click', dinoPressHandler);
  canvas.addEventListener('keydown', e => { if(e.code==='Space'||e.code==='ArrowUp'){e.preventDefault();dinoPressHandler();}});
  canvas.focus();
  dinoReset(canvas);
}

function dinoPressHandler() {
  if (!dinoState) return;
  if (dinoState.over) { dinoReset(document.getElementById('dino-canvas')); return; }
  if (!dinoState.running) { dinoState.running = true; document.getElementById('dino-status').textContent = ''; }
  if (dinoState.dino.onGround) { dinoState.dino.vy = -13; dinoState.dino.onGround = false; }
}

function dinoReset(canvas) {
  if (dinoRAF) cancelAnimationFrame(dinoRAF);
  const best = dinoState ? dinoState.best : parseInt(localStorage.getItem('dinoHighScore')||'0');
  dinoState = {
    running:false, over:false, best,
    score:0, scoreDisplay:0, speed:4, frame:0,
    dino:{ x:60, y:110, w:30, h:40, vy:0, onGround:true },
    obstacles:[], nextObs:80,
    clouds:[], groundX:0
  };
  document.getElementById('dino-score').textContent = '0';
  document.getElementById('dino-best').textContent = best;
  document.getElementById('dino-status').textContent = 'Press Space or Tap to start';
  dinoLoop(canvas);
}

function dinoLoop(canvas) {
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const ground = 140;
  const s = dinoState;

  function draw() {
    ctx.clearRect(0,0,W,H);
    const fg = getComputedStyle(document.documentElement).getPropertyValue('--text').trim() || '#f0ede8';
    const mu = getComputedStyle(document.documentElement).getPropertyValue('--muted').trim() || '#555';
    const ac = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim() || '#e8d5b7';

    // Ground
    ctx.fillStyle = mu;
    ctx.fillRect(0, ground+s.dino.h, W, 2);

    if (s.running && !s.over) {
      s.frame++;
      // Speed up over time
      s.speed = 4 + Math.floor(s.frame / 300) * 0.5;
      // Score
      if (s.frame % 6 === 0) { s.score++; document.getElementById('dino-score').textContent = s.score; }

      // Dino physics
      if (!s.dino.onGround) {
        s.dino.vy += 0.7;
        s.dino.y += s.dino.vy;
        if (s.dino.y >= ground) { s.dino.y = ground; s.dino.vy = 0; s.dino.onGround = true; }
      }

      // Spawn obstacles
      s.nextObs--;
      if (s.nextObs <= 0) {
        const h = 24 + Math.random() * 28;
        s.obstacles.push({ x:W+10, y:ground+s.dino.h-h, w:16, h });
        s.nextObs = 70 + Math.random() * 80 - Math.floor(s.frame/600)*10;
        s.nextObs = Math.max(s.nextObs, 35);
      }
      s.obstacles.forEach(o => o.x -= s.speed);
      s.obstacles = s.obstacles.filter(o => o.x > -40);

      // Collision
      const d = s.dino;
      const pad = 5;
      for (const o of s.obstacles) {
        if (d.x+pad < o.x+o.w-pad && d.x+d.w-pad > o.x+pad && d.y+pad < o.y+o.h && d.y+d.h > o.y+pad) {
          s.over = true;
          if (s.score > s.best) { s.best = s.score; localStorage.setItem('dinoHighScore', s.score); document.getElementById('dino-best').textContent = s.score; }
          document.getElementById('dino-status').textContent = 'Game over! Tap to restart.';
        }
      }
    }

    // Draw dino (pixel-ish rectangle dino)
    ctx.fillStyle = ac;
    ctx.fillRect(s.dino.x, s.dino.y, s.dino.w, s.dino.h);
    // Eye
    ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--bg').trim()||'#0f0f0f';
    ctx.fillRect(s.dino.x+20, s.dino.y+6, 5, 5);
    // Legs (animate)
    if (s.dino.onGround && s.running) {
      const leg = s.frame % 16 < 8;
      ctx.fillStyle = ac;
      ctx.fillRect(s.dino.x+4, s.dino.y+s.dino.h, 8, leg?10:6);
      ctx.fillRect(s.dino.x+16, s.dino.y+s.dino.h, 8, leg?6:10);
    }

    // Draw obstacles (cacti)
    ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--correct').trim()||'#538d4e';
    s.obstacles.forEach(o => {
      ctx.fillRect(o.x, o.y, o.w, o.h);
      ctx.fillRect(o.x-6, o.y+8, 6, o.h-16);
      ctx.fillRect(o.x+o.w, o.y+8, 6, o.h-16);
    });

    // Game over overlay
    if (s.over) {
      ctx.fillStyle = 'rgba(0,0,0,0.35)';
      ctx.fillRect(0,0,W,H);
      ctx.fillStyle = fg;
      ctx.font = `bold 22px 'Space Mono', monospace`;
      ctx.textAlign = 'center';
      ctx.fillText('GAME OVER', W/2, H/2-10);
      ctx.font = `13px 'Space Mono', monospace`;
      ctx.fillStyle = mu;
      ctx.fillText('Tap or press Space to restart', W/2, H/2+16);
      ctx.textAlign = 'left';
    }

    dinoRAF = requestAnimationFrame(draw);
  }
  draw();
}

