// ══════════════════════════════════════════════
// CROSS-DEVICE PREFERENCES SYNC
// ══════════════════════════════════════════════
// Prefs stored in user's DB record under 'prefs' key.
// pfp is stored as base64 — it's large but JSONBin allows up to 5MB per bin.

async function syncPrefsToCloud() {
  if (!currentUser || !IS_CONFIGURED) return;
  const users = await fetchDB();
  const user = users[currentUser];
  if (!user) return;

  // Collect current prefs from localStorage
  const prefs = {};

  // Font
  const savedFont = JSON.parse(localStorage.getItem('wordleGlobalFont') || 'null');
  if (savedFont) prefs.font = savedFont;

  // Colors
  const colors = JSON.parse(localStorage.getItem('wordleColors') || '{}');
  if (Object.keys(colors).length) prefs.colors = colors;

  // Light mode
  prefs.lightMode = !!localStorage.getItem('wordleLight');

  // Background — store color directly; images too large for DB, store as flag
  const bg = JSON.parse(localStorage.getItem('wordleBg') || 'null');
  if (bg && bg.type === 'color') prefs.bg = bg;
  // For image backgrounds: store them as base64 in prefs.bgImage if size allows
  if (bg && bg.type === 'image') {
    try {
      // Check size — skip if >400KB to avoid blowing the 5MB bin
      if (bg.value && bg.value.length < 400000) {
        prefs.bg = bg;
      } else {
        prefs.bg = { type: 'image-toobig' }; // flag: had image but too big to sync
      }
    } catch {}
  }

  // Profile photo
  const photoKey = 'wordleProfilePhoto_' + currentUser;
  const photo = localStorage.getItem(photoKey);
  if (photo) {
    try {
      if (photo.length < 600000) prefs.pfp = photo;
      else prefs.pfp = '__toobig__';
    } catch {}
  }

  user.prefs = prefs;
  dbDirty = true;
  await pushDB();
}

async function loadPrefsFromCloud(username) {
  // Called right after login — pulls prefs from DB and applies them locally
  const users = await fetchDB();
  const user = users[username];
  if (!user || !user.prefs) return;
  const prefs = user.prefs;

  // Light mode
  if (prefs.lightMode) {
    document.body.classList.add('light');
    document.getElementById('toggle-light')?.classList.add('on');
    localStorage.setItem('wordleLight', '1');
  } else {
    document.body.classList.remove('light');
    document.getElementById('toggle-light')?.classList.remove('on');
    localStorage.removeItem('wordleLight');
  }

  // Colors
  if (prefs.colors) {
    localStorage.setItem('wordleColors', JSON.stringify(prefs.colors));
    const root = document.documentElement;
    if (prefs.colors.correct) { root.style.setProperty('--correct', prefs.colors.correct); const el = document.getElementById('color-correct'); if(el) el.value = prefs.colors.correct; }
    if (prefs.colors.present) { root.style.setProperty('--present', prefs.colors.present); const el = document.getElementById('color-present'); if(el) el.value = prefs.colors.present; }
    if (prefs.colors.absent)  { root.style.setProperty('--absent',  prefs.colors.absent);  const el = document.getElementById('color-absent');  if(el) el.value = prefs.colors.absent; }
  }

  // Background
  if (prefs.bg) {
    if (prefs.bg.type === 'color') {
      document.body.style.backgroundColor = prefs.bg.value;
      document.body.classList.add('has-bg');
      localStorage.setItem('wordleBg', JSON.stringify(prefs.bg));
      const el = document.getElementById('bg-color-input'); if (el) el.value = prefs.bg.value;
    } else if (prefs.bg.type === 'image' && prefs.bg.value) {
      document.body.style.backgroundImage = `url(${prefs.bg.value})`;
      document.body.classList.add('has-bg');
      localStorage.setItem('wordleBg', JSON.stringify(prefs.bg));
    }
  }

  // Profile photo
  if (prefs.pfp && prefs.pfp !== '__toobig__') {
    const photoKey = 'wordleProfilePhoto_' + username;
    localStorage.setItem(photoKey, prefs.pfp);
  }

  // Font — load Google Font link if needed, then apply
  if (prefs.font) {
    localStorage.setItem('wordleGlobalFont', JSON.stringify(prefs.font));
    if (prefs.font.id === 'custom-url' && prefs.font.family) {
      // Extract url from family or rebuild from label
      const fontName = prefs.font.label || 'Custom';
      const url = 'https://fonts.googleapis.com/css2?family=' + encodeURIComponent(fontName.replace(/ /g, '+')) + ':wght@400;700&display=swap';
      const link = document.getElementById('custom-font-link');
      if (link) { link.href = url; await new Promise(r => { link.onload = r; link.onerror = r; setTimeout(r, 2000); }); }
    }
    applyGlobalFont(prefs.font.id, prefs.font.family, prefs.font.label);
  }

  renderHeader();
}

async function loadUser() {
  const session = getSession();
  if (!session) { renderHeader(); return; }
  const users = await fetchDB();
  const user = users[session];
  if (user) {
    currentUser = session;
    streak     = user.streak     || 0;
    bestStreak = user.bestStreak || 0;
    await loadPrefsFromCloud(session);
  } else {
    clearSession();
  }
  renderHeader();
}

async function saveUserStats(won) {
  if (!currentUser) return;
  // Always fetch fresh DB — never risk overwriting other players with stale cache
  dbCache = null;
  const users = await fetchDB();
  const user = users[currentUser];
  if (!user) return;

  // Ensure all fields exist for old accounts
  if (user.totalWins  === undefined) user.totalWins  = 0;
  if (user.blitzWins  === undefined) user.blitzWins  = 0;
  if (user.easyWins   === undefined) user.easyWins   = 0;
  if (user.customWins === undefined) user.customWins = 0;
  if (user.blitzBest  === undefined) user.blitzBest  = 0;
  if (user.easyBest   === undefined) user.easyBest   = 0;
  if (user.customBest === undefined) user.customBest = 0;

  user.streak     = streak;
  user.bestStreak = bestStreak;

  const streakKey = gameMode === 'blitz' ? 'blitzBest' : gameMode === 'easy' ? 'easyBest' : gameMode === 'custom' ? 'customBest' : 'bestStreak';
  if (streak > (user[streakKey] || 0)) user[streakKey] = streak;
  if (bestStreak > (user.bestStreak || 0)) user.bestStreak = bestStreak;

  if (won) {
    const winsKey = gameMode === 'blitz' ? 'blitzWins' : gameMode === 'easy' ? 'easyWins' : gameMode === 'custom' ? 'customWins' : 'totalWins';
    user[winsKey] = (user[winsKey] || 0) + 1;

    // Time-period wins
    const now = new Date();
    const wk = Math.ceil((now.getDate() + new Date(now.getFullYear(), now.getMonth(), 1).getDay()) / 7);
    const weekSuffix  = `_w_${now.getFullYear()}_w${wk}_${now.getMonth()}`;
    const monthSuffix = `_m_${now.getFullYear()}_${now.getMonth()}`;
    user[winsKey + weekSuffix]  = (user[winsKey + weekSuffix]  || 0) + 1;
    user[winsKey + monthSuffix] = (user[winsKey + monthSuffix] || 0) + 1;

    // Time-period streaks
    const wStreakKey = streakKey + weekSuffix;
    const mStreakKey = streakKey + monthSuffix;
    if (bestStreak > (user[wStreakKey] || 0)) user[wStreakKey] = bestStreak;
    if (bestStreak > (user[mStreakKey] || 0)) user[mStreakKey] = bestStreak;
  }

  // user is a reference into dbCache[currentUser], so mutation already updated dbCache
  dbDirty = true;
  await pushDB();
  // Force leaderboard to refresh on next open
  dbCache = null;
}

function renderHeader() {
  const authEl = document.getElementById('header-auth');
