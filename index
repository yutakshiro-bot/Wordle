function validatePassword(pw) {
  const hasLetters = (pw.match(/[a-zA-Z]/g) || []).length >= 5;
  const hasNum = /\d/.test(pw);
  const hasSpc = /[^a-zA-Z0-9]/.test(pw);
  return { hasLetters, hasNum, hasSpc, valid: hasLetters && hasNum && hasSpc };
}

function checkPwStrength(pw) {
  const { hasLetters, hasNum, hasSpc } = validatePassword(pw);
  document.getElementById('req-len').classList.toggle('met', hasLetters);
  document.getElementById('req-num').classList.toggle('met', hasNum);
  document.getElementById('req-spc').classList.toggle('met', hasSpc);
  const s = [hasLetters, hasNum, hasSpc].filter(Boolean).length;
  const fill = document.getElementById('pw-fill');
  fill.style.width = (s / 3 * 100) + '%';
  fill.style.background = ['#e06060','#b59f3b','#538d4e'][s - 1] || 'transparent';
}

function resetPwReqs() {
  ['req-len','req-num','req-spc'].forEach(id => document.getElementById(id).classList.remove('met'));
  document.getElementById('pw-fill').style.width = '0%';
}

async function doLogin() {
  const rawInput = document.getElementById('login-username').value.trim();
  const password = document.getElementById('login-password').value;
  const errEl = document.getElementById('login-error');
  errEl.textContent = '';
  if (!rawInput || !password) { errEl.textContent = 'Please fill in all fields.'; return; }
  if (!IS_CONFIGURED) { errEl.textContent = 'Cloud DB not configured — see setup banner.'; return; }
  errEl.textContent = 'Checking…';
  const users = await fetchDB();
  // Case-insensitive match
  const username = Object.keys(users).find(k => k.toLowerCase() === rawInput.toLowerCase()) || rawInput;
  const user = users[username];
  if (!user) { errEl.textContent = 'Username not found.'; return; }
  if (user.passwordHash !== simpleHash(password)) { errEl.textContent = 'Incorrect password.'; return; }
  currentUser = username;
  streak = user.streak || 0;
  bestStreak = user.bestStreak || 0;
  saveSession(username);
  renderHeader(); closeAuth();
  showToast('Welcome back, ' + (user.displayName || username) + '!');
  loadPrefsFromCloud(username);
  loadFriendsBadge();
  startHeartbeat();
  renderSidebarUser();
}

async function doSignup() {
  const username = document.getElementById('su-username').value.trim();
  const email    = document.getElementById('su-email').value.trim();
  const password = document.getElementById('su-password').value;
  const errEl    = document.getElementById('signup-error');
  errEl.textContent = '';
  if (!username || !email || !password) { errEl.textContent = 'Please fill in all fields.'; return; }
  if (username.length > 20) { errEl.textContent = 'Username max 20 characters.'; return; }
  if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { errEl.textContent = 'Invalid email address.'; return; }
  const { valid, hasLetters, hasNum } = validatePassword(password);
  if (!valid) { errEl.textContent = !hasLetters ? 'Password needs at least 5 letters.' : !hasNum ? 'Password needs at least 1 number.' : 'Password needs at least 1 special character.'; return; }
  if (!IS_CONFIGURED) { errEl.textContent = 'Cloud DB not configured — see setup banner.'; return; }
  errEl.textContent = 'Creating account…';
  // Always force a fresh fetch so we have ALL existing users before writing
  dbCache = null;
  const users = await fetchDB();
  if (users[username]) { errEl.textContent = 'Username already taken.'; return; }
  if (Object.values(users).some(u => u.email === email)) { errEl.textContent = 'Email already registered.'; return; }
  const hint = document.getElementById('su-hint').value.trim();
  const newUser = { email, passwordHash: simpleHash(password), hint, streak:0, bestStreak:0, blitzBest:0, easyBest:0, customBest:0, totalWins:0, blitzWins:0, easyWins:0, customWins:0, classicStreak:0, blitzStreak:0, easyStreak:0, customStreak:0, createdAt:Date.now(), prefs:{} };
  // Merge new user into the full existing dataset — never overwrite the whole DB
  dbCache[username] = newUser;
  dbDirty = true;
  await pushDB();
  currentUser = username; streak = 0; bestStreak = 0;
  saveSession(username); renderHeader(); closeAuth();
  showToast('Account created! Welcome, ' + username + '!');
  // Sync any existing local prefs to their new cloud account
  syncPrefsToCloud();
}

async function doLogout() {
  currentUser = null; streak = 0; bestStreak = 0;
  clearSession(); renderHeader(); showToast('Logged out.');
}

function simpleHash(str) {
  let hash = 5381;
  for (let i = 0; i < str.length; i++) { hash = ((hash << 5) + hash) ^ str.charCodeAt(i); }
  return (hash >>> 0).toString(36);
}

