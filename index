// Normalize a user object so every account has all expected fields
function normalizeUser(user) {
  const defaults = {
    streak:0, bestStreak:0, blitzBest:0, easyBest:0, customBest:0,
    totalWins:0, blitzWins:0, easyWins:0, customWins:0,
    classicStreak:0, blitzStreak:0, easyStreak:0, customStreak:0,
    hint: ''
  };
  for (const [k, v] of Object.entries(defaults)) {
    if (user[k] === undefined || user[k] === null) user[k] = v;
  }
  // Social fields
  if (!Array.isArray(user.friends))        user.friends = [];
  if (!Array.isArray(user.friendRequests)) user.friendRequests = [];
  if (!Array.isArray(user.sentRequests))   user.sentRequests = [];
  if (typeof user.messages !== 'object' || user.messages === null) user.messages = {};
  if (typeof user.prefs !== 'object' || user.prefs === null) user.prefs = {};
  return user;
}

async function saveAccountField(field) {
  if (!currentUser || !IS_CONFIGURED) { showToast('Not logged in or DB not configured'); return; }
  const errIdMap = { username:'acct-username-err', email:'acct-email-err', password:'acct-pw-err', hint:'acct-hint-err', bio:'acct-bio-err', displayname:'acct-displayname-err' };
  const errEl = document.getElementById(errIdMap[field] || '') || { textContent:'', style:{} };
  errEl.textContent = '';

  dbCache = null;
  const users = await fetchDB();
  const user = users[currentUser];
  if (!user) { errEl.textContent = 'Account not found.'; return; }

  const ok = (msg) => { showToast(msg); errEl.style.color='var(--correct)'; errEl.textContent='✓ Saved!'; setTimeout(()=>{errEl.textContent='';errEl.style.color='';},2000); };

  if (field === 'displayname') {
    const v = document.getElementById('acct-displayname').value.trim();
    user.displayName = v;
    dbDirty = true; await pushDB(); ok('Display name updated!'); renderHeader();

  } else if (field === 'username') {
    const newName = document.getElementById('acct-username').value.trim();
    if (!newName) { errEl.textContent = 'Username cannot be empty.'; return; }
    if (newName.length > 20) { errEl.textContent = 'Max 20 characters.'; return; }
    // Case-insensitive uniqueness check
    const conflict = Object.keys(users).find(k => k.toLowerCase() === newName.toLowerCase() && k !== currentUser);
    if (conflict) { errEl.textContent = 'Username already taken.'; return; }
    if (newName === currentUser) { errEl.textContent = 'That\'s already your username!'; return; }
    dbCache[newName] = user;
    delete dbCache[currentUser];
    currentUser = newName;
    saveSession(newName);
    dbDirty = true; await pushDB(); renderHeader(); ok('Username updated!');

  } else if (field === 'email') {
    const newEmail = document.getElementById('acct-email').value.trim();
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(newEmail)) { errEl.textContent = 'Invalid email address.'; return; }
    if (Object.entries(users).some(([n, u]) => u.email === newEmail && n !== currentUser)) { errEl.textContent = 'Email already in use.'; return; }
    user.email = newEmail;
    dbDirty = true; await pushDB(); ok('Email updated!');

  } else if (field === 'password') {
    const current = document.getElementById('acct-pw-current').value;
    const newPw = document.getElementById('acct-pw-new').value;
    if (!current) { errEl.textContent = 'Enter your current password.'; return; }
    if (user.passwordHash !== simpleHash(current)) { errEl.textContent = 'Current password is incorrect.'; return; }
    if (!newPw) { errEl.textContent = 'Enter a new password.'; return; }
    const { valid, hasLetters, hasNum } = validatePassword(newPw);
    if (!valid) { errEl.textContent = !hasLetters ? 'Needs at least 5 letters.' : !hasNum ? 'Needs at least 1 number.' : 'Needs at least 1 special char.'; return; }
    user.passwordHash = simpleHash(newPw);
    dbDirty = true; await pushDB();
    document.getElementById('acct-pw-current').value = '';
    document.getElementById('acct-pw-new').value = '';
    document.getElementById('acct-pw-fill').style.width = '0%';
    ['acct-req-len','acct-req-num','acct-req-spc'].forEach(id => document.getElementById(id).classList.remove('met'));
    ok('Password updated!');

  } else if (field === 'hint') {
    user.hint = document.getElementById('acct-hint').value.trim();
    dbDirty = true; await pushDB(); ok('Hint updated!');

  } else if (field === 'bio') {
    user.bio = document.getElementById('acct-bio').value.trim();
    dbDirty = true; await pushDB(); ok('Bio updated!');
  }
}

