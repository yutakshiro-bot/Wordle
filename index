// END GAME
// ══════════════════════════════════════════════
function endGame(won) {
  const elapsed = Math.round((Date.now() - startTime) / 1000);
  const mins = Math.floor(elapsed / 60);
  const secs = elapsed % 60;
  const timeStr = mins > 0 ? `${mins}m ${secs}s` : `${secs}s`;

  if (won) { streak++; if (streak > bestStreak) bestStreak = streak; }
  else { streak = 0; }
  saveUserStats(won);

  const msgs = ['Genius!','Magnificent!','Impressive!','Splendid!','Great!','Phew!'];
  document.getElementById('end-message').textContent = won ? msgs[Math.min(currentRow,5)] : 'Better Luck';
  document.getElementById('answer-reveal').textContent = won ? `You got it in ${currentRow+1}!` : `The word was: ${answer}`;

  const tilesEl = document.getElementById('end-word-tiles');
  tilesEl.innerHTML = '';
  const tileSize = answer.length <= 6 ? '42px' : answer.length <= 9 ? '34px' : '26px';
  answer.split('').forEach((letter, i) => {
    const t = document.createElement('div');
    t.className = 'end-tile correct';
    t.textContent = letter;
    t.style.animationDelay = (i * 80) + 'ms';
    t.style.width = tileSize; t.style.height = tileSize;
    if (answer.length > 8) t.style.fontSize = '0.9rem';
    tilesEl.appendChild(t);
  });

  document.getElementById('stat-guesses').textContent = won ? currentRow + 1 : '✗';
  document.getElementById('stat-streak').textContent = streak;
  document.getElementById('stat-best').textContent = bestStreak;
  document.getElementById('end-time').innerHTML = `<span>Time: </span>${timeStr}`;

  setTimeout(() => {
    const changeBtn = document.getElementById('change-amount-btn');
    if (changeBtn) changeBtn.style.display = gameMode === 'custom' ? 'block' : 'none';
    openOverlay('end-overlay');
  }, 400);
}

