// Track last seen message timestamps per partner for notification purposes
const _seenMsgTs = {};  // { partnerName: latestTs }

async function loadFriendsBadge() {
  if (!currentUser || !IS_CONFIGURED) return;
  const users = await fetchDB();
  const me = users[currentUser];
  if (!me) return;
  ensureSocialFields(me);
  updateFriendsBadge(me);

  // Check for new incoming messages to show notification popup
  _checkForNewMessages(me, users);
}

function _checkForNewMessages(me, users) {
  // Don't notify if DM is already open with that person
  const dmOpen = document.getElementById('dm-overlay')?.classList.contains('show');
  const msgs = me.messages || {};
  let latestNewMsg = null;
  let latestNewFrom = null;
  let latestNewTs = 0;

  Object.entries(msgs).forEach(([partner, convo]) => {
    if (!Array.isArray(convo)) return;
    // Find newest unread message FROM partner (not from me)
    const unread = convo.filter(m => m.from === partner && !m.read);
    if (!unread.length) return;
    const newest = unread[unread.length - 1];
    // Only notify if we haven't already notified for this ts
    const lastSeen = _seenMsgTs[partner] || 0;
    if (newest.ts > lastSeen && newest.ts > latestNewTs) {
      // Skip if DM with this partner is currently open
      if (dmOpen && currentDMUser === partner) return;
      latestNewMsg = newest;
      latestNewFrom = partner;
      latestNewTs = newest.ts;
    }
  });

  if (latestNewMsg && latestNewFrom) {
    _seenMsgTs[latestNewFrom] = latestNewTs;
    showMessageNotif(latestNewFrom, latestNewMsg.text || '', users);
  }
}

