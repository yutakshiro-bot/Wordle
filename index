let msState = null, msTimer = null;
function initMinesweeper() {
  clearInterval(msTimer);
  document.getElementById('ms-msg').textContent = '';
  const diff = document.getElementById('ms-diff').value;
  const configs = { easy:{r:9,c:9,m:10}, medium:{r:16,c:16,m:40}, hard:{r:16,c:30,m:99} };
  const {r,c,m} = configs[diff];
  document.getElementById('ms-mines').textContent = '💣 ' + m;
  document.getElementById('ms-time').textContent = '⏱ 0';
  msState = { rows:r, cols:c, mines:m, board:[], revealed:[], flagged:[], started:false, dead:false, won:false, secs:0 };
  // Init boards
  for (let i=0;i<r;i++) { msState.board.push(Array(c).fill(0)); msState.revealed.push(Array(c).fill(false)); msState.flagged.push(Array(c).fill(false)); }
  renderMsBoard();
}

function placeMines(firstR, firstC) {
  const {rows,cols,mines,board} = msState;
  let placed=0;
  while(placed<mines){const r=Math.floor(Math.random()*rows),c=Math.floor(Math.random()*cols);if(board[r][c]===-1||(Math.abs(r-firstR)<=1&&Math.abs(c-firstC)<=1))continue;board[r][c]=-1;placed++;}
  for(let r=0;r<rows;r++)for(let c=0;c<cols;c++){if(board[r][c]===-1)continue;let n=0;for(let dr=-1;dr<=1;dr++)for(let dc=-1;dc<=1;dc++){const nr=r+dr,nc=c+dc;if(nr>=0&&nr<rows&&nc>=0&&nc<cols&&board[nr][nc]===-1)n++;}board[r][c]=n;}
}

function msReveal(r,c) {
  if(msState.dead||msState.won||msState.revealed[r][c]||msState.flagged[r][c])return;
  if(!msState.started){msState.started=true;placeMines(r,c);msState.secs=0;clearInterval(msTimer);msTimer=setInterval(()=>{msState.secs++;const el=document.getElementById('ms-time');if(el)el.textContent='⏱ '+msState.secs;else clearInterval(msTimer);},1000);}
  msState.revealed[r][c]=true;
  if(msState.board[r][c]===-1){msState.dead=true;clearInterval(msTimer);revealAllMines();renderMsBoard();document.getElementById('ms-msg').textContent='💥 BOOM! Game over.';document.getElementById('ms-msg').style.color='#e06060';return;}
  if(msState.board[r][c]===0){for(let dr=-1;dr<=1;dr++)for(let dc=-1;dc<=1;dc++){const nr=r+dr,nc=c+dc;if(nr>=0&&nr<msState.rows&&nc>=0&&nc<msState.cols&&!msState.revealed[nr][nc])msReveal(nr,nc);}}
  checkMsWin();renderMsBoard();
}

function revealAllMines(){for(let r=0;r<msState.rows;r++)for(let c=0;c<msState.cols;c++)if(msState.board[r][c]===-1)msState.revealed[r][c]=true;}

function msFlag(r,c){if(msState.dead||msState.won||msState.revealed[r][c])return;msState.flagged[r][c]=!msState.flagged[r][c];const remaining=msState.mines-msState.flagged.flat().filter(Boolean).length;document.getElementById('ms-mines').textContent='💣 '+remaining;renderMsBoard();}

function checkMsWin(){const total=msState.rows*msState.cols;const revCount=msState.revealed.flat().filter(Boolean).length;if(revCount===total-msState.mines){msState.won=true;clearInterval(msTimer);document.getElementById('ms-msg').textContent='🎉 You win! Time: '+msState.secs+'s';document.getElementById('ms-msg').style.color='var(--correct)';}}

function renderMsBoard(){
  const el=document.getElementById('ms-board');if(!el)return;
  const numColors=['','#6ca0ff','#4caf7d','#e06060','#7b4b9b','#c0392b','#1abc9c','#2c3e50','#888'];
  let html='<table style="border-collapse:collapse;user-select:none;">';
  for(let r=0;r<msState.rows;r++){html+='<tr>';for(let c=0;c<msState.cols;c++){const rev=msState.revealed[r][c],flag=msState.flagged[r][c],val=msState.board[r][c];
    let content='',bg='var(--key-bg)',color='var(--text)',border='1px solid var(--border)',cursor='pointer';
    if(rev){bg=val===-1?'#e06060':'var(--surface)';content=val===-1?'💣':val>0?val:'';color=numColors[val]||'var(--text)';cursor='default';}
    else if(flag){content='🚩';}
    const sz=msState.cols>16?'18px':'22px';
    html+=`<td onclick="msReveal(${r},${c})" oncontextmenu="event.preventDefault();msFlag(${r},${c})" style="width:${sz};height:${sz};text-align:center;vertical-align:middle;background:${bg};border:${border};font-size:${val>0&&rev?'0.6rem':'0.75rem'};color:${color};cursor:${cursor};font-weight:700;transition:background 0.08s;">${content}</td>`;
  }html+='</tr>';}
  html+='</table>';
  el.innerHTML=html;
}

