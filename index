}

let flState = null, flRAF = null;
function initFlappy() {
  if (flRAF) cancelAnimationFrame(flRAF);
  const best = parseInt(localStorage.getItem('flappyHigh')||'0');
  flState = { running:false, over:false, best, score:0, bird:{x:70,y:190,vy:0,r:12}, pipes:[], frame:0, nextPipe:80 };
  document.getElementById('fl-best').textContent = best;
  const canvas = document.getElementById('fl-canvas');
  if (!canvas) return;
  canvas.addEventListener('click', flTap);
  canvas.addEventListener('keydown', e=>{ if(e.code==='Space'){e.preventDefault();flTap();} });
  canvas.focus();
  _flLoop(canvas);
}

function flTap() {
  if (!flState) return;
  if (flState.over) { initFlappy(); return; }
  if (!flState.running) flState.running = true;
  flState.bird.vy = -7.5;
}

function _flLoop(canvas) {
  const ctx = canvas.getContext('2d');
  const W=canvas.width, H=canvas.height;
  const GAP=110, PW=42;
  const bg=getComputedStyle(document.documentElement).getPropertyValue('--bg').trim();
  const gc=getComputedStyle(document.documentElement).getPropertyValue('--correct').trim();
  const ac=getComputedStyle(document.documentElement).getPropertyValue('--accent').trim();
  const mu=getComputedStyle(document.documentElement).getPropertyValue('--muted').trim();

  function draw() {
    ctx.fillStyle=bg; ctx.fillRect(0,0,W,H);
    const s=flState;
    if (s.running && !s.over) {
      s.frame++;
      // Bird physics
      s.bird.vy += 0.45;
      s.bird.y += s.bird.vy;
      if (s.bird.y - s.bird.r < 0) { s.bird.y = s.bird.r; s.bird.vy = 0; }
      // Pipes
      s.nextPipe--;
      if (s.nextPipe <= 0) {
        const topH = 60 + Math.random()*(H-GAP-120);
        s.pipes.push({ x:W+10, top:topH, scored:false });
        s.nextPipe = 90 + Math.random()*30;
      }
      const speed = 2.5 + s.score*0.08;
      s.pipes.forEach(p => { p.x -= speed; });
      s.pipes = s.pipes.filter(p => p.x > -PW);
      // Score + collision
      const b = s.bird;
      for (const p of s.pipes) {
        if (!p.scored && p.x + PW < b.x) { p.scored=true; s.score++; document.getElementById('fl-score').textContent=s.score; }
        const inX = b.x+b.r-6 > p.x && b.x-b.r+6 < p.x+PW;
        if (inX && (b.y-b.r+4 < p.top || b.y+b.r-4 > p.top+GAP)) { s.over=true; }
      }
      if (b.y + b.r > H-30) s.over = true;
      if (s.over) {
        if (s.score > s.best) { s.best=s.score; localStorage.setItem('flappyHigh',s.score); document.getElementById('fl-best').textContent=s.score; }
      }
    }
    // Draw pipes
    ctx.fillStyle=gc;
    flState.pipes.forEach(p=>{
      ctx.fillRect(p.x,0,PW,p.top);
      ctx.fillRect(p.x,p.top+GAP,PW,H);
      // Pipe caps
      ctx.fillRect(p.x-4,p.top-12,PW+8,12);
      ctx.fillRect(p.x-4,p.top+GAP,PW+8,12);
    });
    // Ground
    ctx.fillStyle=mu; ctx.fillRect(0,H-30,W,30);
    // Bird
    const b=flState.bird;
    ctx.save(); ctx.translate(b.x,b.y);
    ctx.rotate(Math.max(-0.4, Math.min(0.6, b.vy*0.05)));
    ctx.fillStyle=ac; ctx.beginPath(); ctx.ellipse(0,0,b.r,b.r*0.75,0,0,Math.PI*2); ctx.fill();
    ctx.fillStyle='#fff'; ctx.beginPath(); ctx.arc(6,-3,4,0,Math.PI*2); ctx.fill();
    ctx.fillStyle='#1a1a1a'; ctx.beginPath(); ctx.arc(7,-3,2,0,Math.PI*2); ctx.fill();
    ctx.fillStyle='#e06060'; ctx.fillRect(b.r-3,-2,10,5);
    ctx.restore();
    // Overlay
    if (!flState.running || flState.over) {
      ctx.fillStyle='rgba(0,0,0,0.4)'; ctx.fillRect(0,0,W,H);
      ctx.fillStyle='#fff'; ctx.font=`bold 20px 'Space Mono',monospace`; ctx.textAlign='center';
      ctx.fillText(flState.over?'GAME OVER':'TAP TO START', W/2, H/2-12);
      if (flState.over) { ctx.font=`13px 'Space Mono',monospace`; ctx.fillStyle='rgba(255,255,255,0.6)'; ctx.fillText('Tap to restart', W/2, H/2+12); }
      ctx.textAlign='left';
    }
    flRAF=requestAnimationFrame(draw);
  }
  draw();
}


